<Window x:Class="PolarisManager.DemoAI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaSCM — Software Deployment Console"
        Height="720" Width="1120" WindowStartupLocation="CenterScreen"
        Background="#F4F6FA">
    <Window.Resources>
        <Style x:Key="SideNavBtn" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#9EC5EF"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SideNavBtnActive" TargetType="Button" BasedOn="{StaticResource SideNavBtn}">
            <Setter Property="Background" Value="#0958B8"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#F4F6FA"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="Padding" Value="14,9"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E4EC"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#EBF3FF"/>
                    <Setter Property="Foreground" Value="#1A3C8F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="14,0"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>
        <!-- ═══ HEADER ═══ -->
        <Border DockPanel.Dock="Top" Background="#073682" Height="54">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0A78C9" Width="34" Height="34" CornerRadius="7" Margin="0,0,12,0">
                        <TextBlock Text="N" Foreground="White" FontSize="19" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NovaSCM" Foreground="White" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="   Console" Foreground="#5588CC" FontSize="14"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button Background="Transparent" BorderThickness="0" Foreground="#7AAAD8"
                            FontSize="13" Padding="14,0" Cursor="Hand">Dashboard</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="White"
                            FontSize="13" FontWeight="SemiBold" Padding="14,0" Cursor="Hand">Deployment</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#7AAAD8"
                            FontSize="13" Padding="14,0" Cursor="Hand">Dispositivi</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#7AAAD8"
                            FontSize="13" Padding="14,0" Cursor="Hand">Report</Button>
                    <Button Background="Transparent" BorderThickness="0" Foreground="#7AAAD8"
                            FontSize="13" Padding="14,0" Cursor="Hand">Admin</Button>
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#0A5CB8" CornerRadius="15" Width="30" Height="30" Margin="0,0,8,0">
                        <TextBlock Text="A" Foreground="White" FontSize="14" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Admin" Foreground="White" FontSize="13" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ SIDEBAR ═══ -->
        <Border DockPanel.Dock="Left" Background="#0A78C9" Width="204">
            <StackPanel>
                <TextBlock Text="NAVIGAZIONE" Foreground="#5599DD" FontSize="10"
                           FontWeight="Bold" Margin="18,18,18,6"/>
                <Button Content="&#x1F3E0;   Dashboard"      Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x1F4E6;   Applicazioni"   Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x2699;&#xFE0F;   Workflow"       Style="{StaticResource SideNavBtnActive}"/>
                <Button Content="&#x1F5A5;&#xFE0F;   Dispositivi"    Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x1F4BF;   Deploy OS"      Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x1F4E1;   Aggiornamenti"  Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x1F4CB;   Change Request" Style="{StaticResource SideNavBtn}"/>
                <TextBlock Text="SISTEMA" Foreground="#5599DD" FontSize="10"
                           FontWeight="Bold" Margin="18,16,18,6"/>
                <Button Content="&#x1F512;   Certificati"   Style="{StaticResource SideNavBtn}"/>
                <Button Content="&#x2699;&#xFE0F;   Impostazioni"  Style="{StaticResource SideNavBtn}"/>
            </StackPanel>
        </Border>

        <!-- ═══ MAIN CONTENT ═══ -->
        <ScrollViewer Background="#F4F6FA" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="28,22">

                <!-- Breadcrumb + Title -->
                <TextBlock Text="Workflow  /  Deploy Base Windows 11  /  Assegnazioni"
                           FontSize="12" Foreground="#8899BB" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,22">
                    <TextBlock Text="Assegnazioni Workflow" FontSize="24"
                               FontWeight="Bold" Foreground="#1A2340" VerticalAlignment="Center"/>
                    <Border Background="#E8F0FE" BorderBrush="#AABBEE" BorderThickness="1"
                            CornerRadius="12" Padding="12,4" Margin="14,4,0,0" VerticalAlignment="Center">
                        <TextBlock Text="Deploy Base Windows 11" Foreground="#1A3C8F" FontSize="12"/>
                    </Border>
                </StackPanel>

                <!-- Stat cards -->
                <UniformGrid Rows="1" Margin="0,0,0,22">
                    <Border Background="White" BorderBrush="#E0E6F0" BorderThickness="1"
                            CornerRadius="8" Padding="22,16" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="TOTALE PC" FontSize="11" Foreground="#999" FontWeight="Bold"/>
                            <TextBlock Text="6" FontSize="34" FontWeight="Bold" Foreground="#0A78C9" Margin="0,4,0,2"/>
                            <TextBlock Text="Assegnazioni attive" FontSize="11" Foreground="#BBB"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E6F0" BorderThickness="1"
                            CornerRadius="8" Padding="22,16" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="COMPLETATI" FontSize="11" Foreground="#999" FontWeight="Bold"/>
                            <TextBlock Text="1" FontSize="34" FontWeight="Bold" Foreground="#16A34A" Margin="0,4,0,2"/>
                            <TextBlock Text="Deploy riusciti" FontSize="11" Foreground="#BBB"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E6F0" BorderThickness="1"
                            CornerRadius="8" Padding="22,16" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="IN ESECUZIONE" FontSize="11" Foreground="#999" FontWeight="Bold"/>
                            <TextBlock Text="2" FontSize="34" FontWeight="Bold" Foreground="#2563EB" Margin="0,4,0,2"/>
                            <TextBlock Text="Deploy attivi ora" FontSize="11" Foreground="#BBB"/>
                        </StackPanel>
                    </Border>
                    <Border Background="White" BorderBrush="#E0E6F0" BorderThickness="1"
                            CornerRadius="8" Padding="22,16" Margin="0">
                        <StackPanel>
                            <TextBlock Text="IN ATTESA" FontSize="11" Foreground="#999" FontWeight="Bold"/>
                            <TextBlock Text="3" FontSize="34" FontWeight="Bold" Foreground="#9CA3AF" Margin="0,4,0,2"/>
                            <TextBlock Text="In coda" FontSize="11" Foreground="#BBB"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Card con DataGrid -->
                <Border Background="White" BorderBrush="#E0E6F0" BorderThickness="1" CornerRadius="8">
                    <StackPanel>
                        <!-- Toolbar -->
                        <Border Background="#F8F9FC" BorderBrush="#E0E6F0" BorderThickness="0,0,0,1"
                                CornerRadius="8,8,0,0">
                            <StackPanel Orientation="Horizontal" Margin="14,10">
                                <Button Content="+ Assegna PC" Padding="16,8" Margin="0,0,8,0"
                                        Background="#0A78C9" Foreground="White"
                                        BorderThickness="0" FontSize="13" Cursor="Hand"/>
                                <Button Content="&#x25B6; Avvia Deploy" Padding="16,8" Margin="0,0,8,0"
                                        Background="White" Foreground="#0A78C9"
                                        BorderBrush="#0A78C9" BorderThickness="1"
                                        FontSize="13" Cursor="Hand"/>
                                <Button Content="&#x1F504; Aggiorna" Padding="16,8" Margin="0,0,8,0"
                                        Background="White" Foreground="#555"
                                        BorderBrush="#DDD" BorderThickness="1"
                                        FontSize="13" Cursor="Hand"/>
                                <Button Content="&#x1F5D1; Rimuovi" Padding="16,8"
                                        Background="White" Foreground="#DC2626"
                                        BorderBrush="#FCA5A5" BorderThickness="1"
                                        FontSize="13" Cursor="Hand"/>
                            </StackPanel>
                        </Border>
                        <!-- DataGrid -->
                        <DataGrid x:Name="GridResultsAI"
                                  AutoGenerateColumns="False" CanUserAddRows="False"
                                  SelectionMode="Single"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalGridLinesBrush="#EEF0F6"
                                  Background="White" BorderThickness="0" RowHeight="44">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Nome PC"         Binding="{Binding Name}"     Width="160" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Stato"           Binding="{Binding Status}"   Width="145" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Progresso"       Binding="{Binding Progress}" Width="100" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Dominio"         Binding="{Binding Domain}"   Width="180" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Ultimo contatto" Binding="{Binding LastSeen}" Width="140" IsReadOnly="True"/>
                                <DataGridTextColumn Header="Note"            Binding="{Binding Notes}"    Width="*"   IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
