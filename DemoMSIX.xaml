<!-- NovaSCM v1.6.0 -->
<Window x:Class="PolarisManager.DemoMSIX"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="NovaSCM — Wizard Deployment"
        Height="660" Width="980" WindowStartupLocation="CenterScreen"
        Background="White" ResizeMode="CanMinimize">
    <Window.Resources>
        <Style x:Key="StepDone" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#0078D4"/>
        </Style>
        <Style x:Key="StepCurrent" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#0078D4"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>
        <Style x:Key="StepFuture" TargetType="Border">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Background" Value="#CCCCCC"/>
        </Style>
        <Style x:Key="PkgCheckBox" TargetType="CheckBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,12"/>
            <Setter Property="Foreground" Value="#222"/>
        </Style>
        <Style x:Key="ActionBtnPrimary" TargetType="Button">
            <Setter Property="Background" Value="#0078D4"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style x:Key="ActionBtnSecondary" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="BorderBrush" Value="#AAA"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="28,10"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="252"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══ LEFT WIZARD PANEL ═══ -->
        <Border Grid.Column="0" Background="#F3F3F3" BorderBrush="#E0E0E0" BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App header -->
                <Border DockPanel.Dock="Top" Background="#0078D4" Padding="18,16">
                    <StackPanel Orientation="Horizontal">
                        <Border Background="#005FA3" Width="32" Height="32" CornerRadius="6" Margin="0,0,10,0">
                            <TextBlock Text="N" Foreground="White" FontSize="17" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="NovaSCM" Foreground="White" FontSize="14" FontWeight="Bold"/>
                            <TextBlock Text="Wizard Deployment" Foreground="#A8D0F0" FontSize="11"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Steps list -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,0">

                    <!-- Step 1 — Done -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepDone}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                            <TextBlock Text="&#x2713;" Foreground="White" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Tipo di deploy" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                            <TextBlock Text="Workflow — Software" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- Connector -->
                    <Border Width="2" Height="18" Background="#0078D4" HorizontalAlignment="Left" Margin="13,0,0,0"/>

                    <!-- Step 2 — Done -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepDone}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                            <TextBlock Text="&#x2713;" Foreground="White" FontSize="14" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="PC target" FontSize="13" Foreground="#0078D4" FontWeight="SemiBold"/>
                            <TextBlock Text="6 dispositivi selezionati" FontSize="11" Foreground="#888" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- Connector -->
                    <Border Width="2" Height="18" Background="#0078D4" HorizontalAlignment="Left" Margin="13,0,0,0"/>

                    <!-- Step 3 — Current -->
                    <Border Background="#E8F1FB" CornerRadius="6" Padding="0,8" Margin="-8,0,-8,0">
                        <Grid Margin="8,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="32"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource StepCurrent}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                                <TextBlock Text="3" Foreground="#0078D4" FontSize="13" FontWeight="Bold"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                <TextBlock Text="Configura pacchetti" FontSize="13" Foreground="#0078D4" FontWeight="Bold"/>
                                <TextBlock Text="Scegli software da installare" FontSize="11" Foreground="#555" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                    <!-- Connector -->
                    <Border Width="2" Height="18" Background="#D0D0D0" HorizontalAlignment="Left" Margin="13,0,0,0"/>

                    <!-- Step 4 — Future -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepFuture}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                            <TextBlock Text="4" Foreground="White" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Parametri avanzati" FontSize="13" Foreground="#888"/>
                            <TextBlock Text="Riavvio, policy, timeout" FontSize="11" Foreground="#BBB" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- Connector -->
                    <Border Width="2" Height="18" Background="#D0D0D0" HorizontalAlignment="Left" Margin="13,0,0,0"/>

                    <!-- Step 5 — Future -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepFuture}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                            <TextBlock Text="5" Foreground="White" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Pianificazione" FontSize="13" Foreground="#888"/>
                            <TextBlock Text="Data e ora di esecuzione" FontSize="11" Foreground="#BBB" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                    <!-- Connector -->
                    <Border Width="2" Height="18" Background="#D0D0D0" HorizontalAlignment="Left" Margin="13,0,0,0"/>

                    <!-- Step 6 — Future -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Style="{StaticResource StepFuture}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,2,0,0">
                            <TextBlock Text="6" Foreground="White" FontSize="13"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="10,0,0,0">
                            <TextBlock Text="Conferma ed esegui" FontSize="13" Foreground="#888"/>
                            <TextBlock Text="Riepilogo e avvio" FontSize="11" Foreground="#BBB" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ═══ RIGHT CONTENT ═══ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="64"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- Step header -->
            <Border Grid.Row="0" Background="#0078D4">
                <StackPanel Margin="28,0" VerticalAlignment="Center">
                    <TextBlock Text="Passaggio 3 di 6 — Configura pacchetti" Foreground="#A8D0F0" FontSize="11"/>
                    <TextBlock Text="Scegli i software da installare su tutti i PC target" Foreground="White" FontSize="16" FontWeight="SemiBold"/>
                </StackPanel>
            </Border>

            <!-- Step content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="White">
                <StackPanel Margin="32,28">

                    <!-- Info box -->
                    <Border Background="#F0F6FF" BorderBrush="#B8D4F8" BorderThickness="1"
                            CornerRadius="6" Padding="16,12" Margin="0,0,0,24">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#x2139;" FontSize="18" Foreground="#0078D4" Margin="0,0,10,0" VerticalAlignment="Top"/>
                            <TextBlock FontSize="12" Foreground="#333" TextWrapping="Wrap">
                                <Run Text="I pacchetti selezionati verranno installati tramite " FontWeight="Normal"/>
                                <Run Text="winget" FontWeight="Bold"/>
                                <Run Text=" su tutti i 6 PC target. L'installazione avviene in modalita' silenziosa." FontWeight="Normal"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Package list -->
                    <TextBlock Text="Applicazioni disponibili" FontSize="14" FontWeight="SemiBold" Foreground="#111" Margin="0,0,0,16"/>

                    <DataGrid x:Name="GridPkg"
                              AutoGenerateColumns="False" CanUserAddRows="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HorizontalGridLinesBrush="#EEF0F4"
                              Background="White" BorderBrush="#E0E4EC" BorderThickness="1"
                              RowHeight="40">
                        <DataGrid.Resources>
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="#F4F6FA"/>
                                <Setter Property="Foreground" Value="#555"/>
                                <Setter Property="Padding" Value="12,8"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="BorderBrush" Value="#DDE0E8"/>
                                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                            </Style>
                            <Style TargetType="DataGridRow">
                                <Setter Property="Background" Value="White"/>
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#E8F1FB"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                            <Style TargetType="DataGridCell">
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="DataGridCell">
                                            <Border Background="{TemplateBinding Background}">
                                                <ContentPresenter Margin="12,0"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Binding="{Binding Selected}" Width="44" IsReadOnly="False"/>
                            <DataGridTextColumn Header="Icona"     Binding="{Binding Icon}"    Width="50"  IsReadOnly="True"/>
                            <DataGridTextColumn Header="Nome"      Binding="{Binding Name}"    Width="200" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Winget ID" Binding="{Binding WingetId}" Width="240" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Versione"  Binding="{Binding Version}" Width="*"   IsReadOnly="True"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <!-- Custom package input -->
                    <TextBlock Text="Aggiungi pacchetto personalizzato" FontSize="13" FontWeight="SemiBold"
                               Foreground="#333" Margin="0,24,0,8"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border BorderBrush="#CCCCCC" BorderThickness="1" CornerRadius="4">
                            <TextBox Text="Es: Notepad++.Notepad++" Background="White"
                                     Foreground="#888" BorderThickness="0" Padding="12,8" FontSize="13"/>
                        </Border>
                        <Button Grid.Column="1" Content="+ Aggiungi" Margin="8,0,0,0"
                                Style="{StaticResource ActionBtnPrimary}" Padding="20,9"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- Navigation buttons -->
            <Border Grid.Row="2" Background="#F7F7F7" BorderBrush="#E0E0E0" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Margin="0,0,28,0">
                    <Button Content="&#x2190; Indietro" Style="{StaticResource ActionBtnSecondary}" Margin="0,0,10,0"/>
                    <Button Content="Avanti &#x2192;" Style="{StaticResource ActionBtnPrimary}" Margin="0,0,10,0"/>
                    <Button Content="Annulla" Style="{StaticResource ActionBtnSecondary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
