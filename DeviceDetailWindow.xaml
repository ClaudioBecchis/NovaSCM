<!-- NovaSCM v1.5.0 -->
<Window x:Class="PolarisManager.DeviceDetailWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="Dettaglio Device" Height="520" Width="560"
        WindowStartupLocation="CenterOwner" MinWidth="480">

    <Window.Resources>
        <Style x:Key="InfoLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#64748b"/>
            <Setter Property="FontSize"   Value="12"/>
        </Style>
        <Style x:Key="InfoValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#e2e8f0"/>
            <Setter Property="FontSize"   Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="PortBtn" TargetType="Button">
            <Setter Property="Padding"        Value="10,4"/>
            <Setter Property="Margin"         Value="4,0,0,0"/>
            <Setter Property="FontSize"       Value="12"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style x:Key="BtnRdp" TargetType="Button" BasedOn="{StaticResource PortBtn}">
            <Setter Property="Background"  Value="#0c1e40"/>
            <Setter Property="BorderBrush" Value="#2563eb"/>
            <Setter Property="Foreground"  Value="#93c5fd"/>
        </Style>
        <Style x:Key="BtnSsh" TargetType="Button" BasedOn="{StaticResource PortBtn}">
            <Setter Property="Background"  Value="#052e16"/>
            <Setter Property="BorderBrush" Value="#16a34a"/>
            <Setter Property="Foreground"  Value="#4ade80"/>
        </Style>
        <Style x:Key="BtnWeb" TargetType="Button" BasedOn="{StaticResource PortBtn}">
            <Setter Property="Background"  Value="#2d1a00"/>
            <Setter Property="BorderBrush" Value="#d97706"/>
            <Setter Property="Foreground"  Value="#fcd34d"/>
        </Style>
        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource PortBtn}">
            <Setter Property="Background"  Value="#052e16"/>
            <Setter Property="BorderBrush" Value="#16a34a"/>
            <Setter Property="Foreground"  Value="#4ade80"/>
            <Setter Property="Padding"     Value="14,6"/>
        </Style>
        <Style x:Key="BtnBlue" TargetType="Button" BasedOn="{StaticResource PortBtn}">
            <Setter Property="Background"  Value="#0c1e40"/>
            <Setter Property="BorderBrush" Value="#2563eb"/>
            <Setter Property="Foreground"  Value="#93c5fd"/>
            <Setter Property="Padding"     Value="14,6"/>
        </Style>
    </Window.Resources>

    <Grid Background="#0a0f1e">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header device -->
        <Border Grid.Row="0" Background="#0d1b3e" Padding="20,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="TxtDeviceName" FontSize="18" FontWeight="Bold"
                               Foreground="#60a5fa"/>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="IP: " Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="TxtIp" Style="{StaticResource InfoValue}" Margin="0,0,16,0"/>
                        <TextBlock Text="MAC: " Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="TxtMac" Style="{StaticResource InfoValue}" Margin="0,0,16,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                        <TextBlock Text="Vendor: " Style="{StaticResource InfoLabel}"/>
                        <TextBlock x:Name="TxtVendor" Style="{StaticResource InfoValue}"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock Grid.Column="1" x:Name="TxtStatus" FontSize="22"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Progress scansione porte -->
        <StackPanel Grid.Row="1" Margin="20,12,20,4">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                <TextBlock Text="🔍  Scansione porte" Foreground="#60a5fa"
                           FontSize="13" FontWeight="SemiBold"/>
                <TextBlock x:Name="TxtPortStatus" Foreground="#475569"
                           FontSize="12" Margin="12,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
            <ProgressBar x:Name="PortProgress" Height="4" Background="#0d1b3e"
                         Foreground="#3b82f6" BorderThickness="0"
                         Minimum="0" Maximum="100" Value="0"/>
        </StackPanel>

        <!-- Lista porte aperte -->
        <ScrollViewer Grid.Row="2" Margin="20,8,20,0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock x:Name="TxtNoPorte" Text="Nessuna porta aperta trovata finora..."
                           Foreground="#334155" FontSize="12" Margin="0,8,0,0"/>
                <ItemsControl x:Name="PortList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#0d1b3e" BorderBrush="#1e3a5f"
                                    BorderThickness="0,0,0,1" Padding="12,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="70"/>
                                        <ColumnDefinition Width="160"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding PortDisplay}"
                                               Foreground="#10b981" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding ServiceName}"
                                               Foreground="#94a3b8" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal"
                                                HorizontalAlignment="Right">
                                        <Button Content="{Binding ActionLabel}"
                                                Style="{Binding ActionStyle}"
                                                Tag="{Binding}"
                                                Visibility="{Binding ActionVisibility}"
                                                Click="PortAction_Click"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Riepilogo -->
        <TextBlock Grid.Row="3" x:Name="TxtSummary"
                   Foreground="#475569" FontSize="11" Margin="20,8,20,4"/>

        <!-- Pulsanti azione -->
        <Border Grid.Row="4" Background="#0d1b3e" BorderThickness="0,1,0,0"
                BorderBrush="#1e3a5f" Padding="16,10">
            <StackPanel Orientation="Horizontal">
                <Button Content="🔐  Genera Cert" Style="{StaticResource BtnGreen}"
                        Click="BtnGenCert_Click" Margin="0,0,8,0"/>
                <Button Content="➕  Registra" Style="{StaticResource BtnBlue}"
                        Click="BtnRegister_Click" Margin="0,0,8,0"/>
                <Button Content="❌  Chiudi" Click="BtnClose_Click"
                        Margin="0,0,0,0" Padding="14,6"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
