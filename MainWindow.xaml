<Window x:Class="PolarisManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="NovaSCM — by Claudio Becchis" Icon="Assets/novascm.ico"
        Height="780" Width="1300"
        MinHeight="560" MinWidth="900"
        FontSize="14"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown">

    <Window.Resources>
        <!-- Colori base -->
        <SolidColorBrush x:Key="NavyBrush"     Color="#0d1b3e"/>
        <SolidColorBrush x:Key="AccentBrush"   Color="#3b82f6"/>
        <SolidColorBrush x:Key="GreenBrush"    Color="#10b981"/>
        <SolidColorBrush x:Key="RedBrush"      Color="#ef4444"/>
        <SolidColorBrush x:Key="AmberBrush"    Color="#f59e0b"/>
        <SolidColorBrush x:Key="MutedBrush"    Color="#475569"/>
        <SolidColorBrush x:Key="SubtleBrush"   Color="#1e3a5f"/>

        <!-- Stat card style -->
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background"      Value="White"/>
            <Setter Property="BorderBrush"     Value="#E0E6F0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="7"/>
            <Setter Property="Padding"         Value="18,12"/>
            <Setter Property="Margin"          Value="0,0,12,0"/>
        </Style>

        <!-- Pulsante base -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Padding"         Value="16,8"/>
            <Setter Property="Margin"          Value="0,0,8,0"/>
            <Setter Property="FontSize"        Value="13"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.82"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.65"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.38"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="BtnGreen" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#16a34a"/>
            <Setter Property="BorderBrush"  Value="#15803d"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>
        <Style x:Key="BtnRed" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#dc2626"/>
            <Setter Property="BorderBrush"  Value="#b91c1c"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>
        <Style x:Key="BtnBlue" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#2563eb"/>
            <Setter Property="BorderBrush"  Value="#1d4ed8"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>
        <Style x:Key="BtnAmber" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"   Value="#d97706"/>
            <Setter Property="BorderBrush"  Value="#b45309"/>
            <Setter Property="Foreground"   Value="White"/>
        </Style>

        <!-- Label sezione -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"     Value="14"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Foreground"   Value="#1D4ED8"/>
            <Setter Property="Margin"       Value="0,0,0,10"/>
        </Style>

        <!-- DataGrid light -->
        <Style TargetType="DataGrid">
            <Setter Property="Background"               Value="White"/>
            <Setter Property="RowBackground"            Value="White"/>
            <Setter Property="AlternatingRowBackground" Value="#F7F9FC"/>
            <Setter Property="BorderThickness"          Value="1"/>
            <Setter Property="BorderBrush"              Value="#D0D5DC"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#E4E8F0"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="IsReadOnly"               Value="True"/>
            <Setter Property="FontSize"                 Value="13"/>
            <Setter Property="RowHeight"                Value="36"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="#ECEEF3"/>
            <Setter Property="Foreground"      Value="#444444"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Padding"         Value="10,7"/>
            <Setter Property="BorderBrush"     Value="#CDD1D8"/>
            <Setter Property="BorderThickness" Value="0,0,1,1"/>
        </Style>
        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="#222222"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#DBEAFE"/>
                    <Setter Property="Foreground" Value="#1E3A8A"/>
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#EFF6FF"/>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="Padding"          Value="10,4"/>
            <Setter Property="BorderThickness"  Value="0"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
        </Style>

        <!-- TextBox settings -->
        <Style x:Key="SettingsBox" TargetType="TextBox">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Foreground"   Value="#1a1a1a"/>
            <Setter Property="BorderBrush"  Value="#C8CDD5"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Width"        Value="320"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="SettingsPass" TargetType="PasswordBox">
            <Setter Property="Background"   Value="White"/>
            <Setter Property="Foreground"   Value="#1a1a1a"/>
            <Setter Property="BorderBrush"  Value="#C8CDD5"/>
            <Setter Property="Padding"      Value="8,4"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="Width"        Value="320"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>
        <Style x:Key="SettingsLabel" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#555555"/>
            <Setter Property="FontSize"     Value="12"/>
            <Setter Property="Margin"       Value="0,10,0,3"/>
        </Style>
        <Style x:Key="GroupTitle" TargetType="TextBlock">
            <Setter Property="Foreground"   Value="#1D4ED8"/>
            <Setter Property="FontSize"     Value="13"/>
            <Setter Property="FontWeight"   Value="SemiBold"/>
            <Setter Property="Margin"       Value="0,16,0,6"/>
        </Style>

        <!-- Sidebar nav button (hidden, kept for code compatibility) -->
        <Style x:Key="NavSideBtn"       TargetType="Button"/>
        <Style x:Key="NavSideBtnActive" TargetType="Button"/>

        <!-- ── Ribbon / SCCM Console styles ── -->
        <Style x:Key="RibbonTab" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="#9AAFC8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"       Value="16,0"/>
            <Setter Property="FontSize"      Value="12"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" Height="32">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="RibbonTabActive" TargetType="Button" BasedOn="{StaticResource RibbonTab}">
            <Setter Property="Foreground"  Value="White"/>
            <Setter Property="FontWeight"  Value="SemiBold"/>
            <Setter Property="Background"  Value="#2B579A"/>
        </Style>
        <Style x:Key="RibbonBtn" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"         Value="64"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="4,6">
                            <ContentPresenter HorizontalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A6AAF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#1A4A8F"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WsBtn" TargetType="Button">
            <Setter Property="Background"    Value="Transparent"/>
            <Setter Property="Foreground"    Value="#6688AA"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor"        Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="6,8">
                            <StackPanel>
                                <TextBlock Text="{TemplateBinding Tag}" FontSize="17"
                                           HorizontalAlignment="Center"
                                           Foreground="{TemplateBinding Foreground}"/>
                                <TextBlock Text="{TemplateBinding Content}" FontSize="9"
                                           HorizontalAlignment="Center" Margin="0,2,0,0"
                                           Foreground="{TemplateBinding Foreground}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#2A4A7A"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#163060"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="WsBtnActive" TargetType="Button" BasedOn="{StaticResource WsBtn}">
            <Setter Property="Background" Value="#2B579A"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Resources>

    <Grid>
    <DockPanel Background="#F4F6FA">

        <!-- ═══ RIBBON (SCCM Console style) ═══ -->
        <Grid DockPanel.Dock="Top">
            <Grid.RowDefinitions>
                <RowDefinition Height="32"/>
                <RowDefinition Height="68"/>
            </Grid.RowDefinitions>

            <!-- Tab bar -->
            <Grid Grid.Row="0" Background="#1F3864">
                <StackPanel Orientation="Horizontal">
                    <Border Background="#0F2848" Width="50">
                        <TextBlock Text="N" Foreground="White" FontSize="18" FontWeight="Bold"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="RibbonTabHome" Content="Home"       Style="{StaticResource RibbonTabActive}" Tag="home"  Click="RibbonTab_Click"/>
                    <Button                         Content="Visualizza" Style="{StaticResource RibbonTab}"       Tag="view"  Click="RibbonTab_Click"/>
                    <Button                         Content="Strumenti"  Style="{StaticResource RibbonTab}"       Tag="tools" Click="RibbonTab_Click"/>
                </StackPanel>
                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,14,0">
                    <TextBlock x:Name="TxtNavSection" Foreground="#7AAAD8" FontSize="12"
                               FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock x:Name="TxtHeaderStatus" Text="● Pronto"
                               Foreground="#10b981" FontSize="12" VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Action bar -->
            <Border Grid.Row="1" Background="#2B579A">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"
                               Margin="0,0,20,0" Foreground="#4A6A9A" FontSize="11"
                               Text="NovaSCM Console  •  © 2026 Claudio Becchis"/>
                    <StackPanel Orientation="Horizontal" Margin="8,0">
                        <!-- Gestione -->
                        <StackPanel Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnNuovo_Click">
                                    <StackPanel><TextBlock Text="📋" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Nuovo" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnProprieta_Click">
                                    <StackPanel><TextBlock Text="✏️" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Proprietà" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnElimina_Click">
                                    <StackPanel><TextBlock Text="🗑" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Elimina" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Gestione" FontSize="10" Foreground="#7799CC" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="#1F4888" Margin="6,10"/>
                        <!-- Distribuzione -->
                        <StackPanel Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnDistribuisci_Click">
                                    <StackPanel><TextBlock Text="🚀" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Distribuisci" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnStato_Click">
                                    <StackPanel><TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Stato" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnAggiorna_Click">
                                    <StackPanel><TextBlock Text="🔄" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Aggiorna" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Distribuzione" FontSize="10" Foreground="#7799CC" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                        <Border Width="1" Background="#1F4888" Margin="6,10"/>
                        <!-- Strumenti -->
                        <StackPanel Margin="4,0">
                            <StackPanel Orientation="Horizontal">
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnImporta_Click">
                                    <StackPanel><TextBlock Text="📥" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Importa" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnEsporta_Click">
                                    <StackPanel><TextBlock Text="📤" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Esporta" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                                <Button Style="{StaticResource RibbonBtn}" Click="RibbonBtnImpostazioni_Click">
                                    <StackPanel><TextBlock Text="⚙️" FontSize="20" HorizontalAlignment="Center"/><TextBlock Text="Impostazioni" FontSize="10" HorizontalAlignment="Center" Foreground="#BBCCE8"/></StackPanel>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="Strumenti" FontSize="10" Foreground="#7799CC" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </DockPanel>
            </Border>
        </Grid>

        <!-- ═══ STATUS BAR ═══ -->
        <Border DockPanel.Dock="Bottom" Background="#E8EDF5" Height="24"
                BorderBrush="#C8D0DC" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                <TextBlock Text="NovaSCM" Foreground="#1D4ED8" FontSize="11" FontWeight="SemiBold"/>
                <TextBlock Text="  ·  " Foreground="#94a3b8" FontSize="11"/>
                <TextBlock Text="© 2026 Claudio Becchis — PolarisCore.it" Foreground="#64748b" FontSize="11"/>
                <TextBlock Text="  │  " Foreground="#94a3b8" FontSize="11"/>
                <TextBlock Text="8/10 online" Foreground="#15803d" FontSize="11"/>
                <TextBlock Text="  │  " Foreground="#94a3b8" FontSize="11"/>
                <TextBlock Text="4 cert" Foreground="#1D4ED8" FontSize="11"/>
                <TextBlock Text="  │  " Foreground="#94a3b8" FontSize="11"/>
                <TextBlock Text="3/4 PC" Foreground="#7c3aed" FontSize="11"/>
                <TextBlock Text="  │  " Foreground="#94a3b8" FontSize="11"/>
                <TextBlock x:Name="StatusBarMsg" Text="Pronto" Foreground="#64748b" FontSize="11"/>
            </StackPanel>
        </Border>

        <!-- ═══ UPDATE BANNER ═══ -->
        <Border x:Name="UpdateBanner" DockPanel.Dock="Top"
                Background="#1a1200" BorderBrush="#f59e0b" BorderThickness="0,0,0,2"
                Visibility="Collapsed" Padding="14,7">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="TxtUpdateBanner" Grid.Column="0"
                           Foreground="#fbbf24" FontSize="13" VerticalAlignment="Center"/>
                <Button x:Name="BtnInstallUpdate" Grid.Column="1"
                        Content="⬇️  Installa ora" Margin="0,0,8,0"
                        Background="#0c2d1a" BorderBrush="#16a34a" Foreground="#4ade80"
                        Padding="12,4" Cursor="Hand" FontSize="12"
                        Click="BtnInstallUpdate_Click"/>
                <Button Grid.Column="2" Content="✕" Padding="8,4" Cursor="Hand"
                        Background="Transparent" BorderThickness="0" Foreground="#475569"
                        FontSize="13" Click="BtnDismissUpdate_Click"/>
            </Grid>
        </Border>

        <!-- ═══ LEFT NAV (SCCM Console style) ═══ -->
        <Grid DockPanel.Dock="Left" Width="236">
            <Grid.RowDefinitions>
                <RowDefinition Height="28"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="64"/>
            </Grid.RowDefinitions>

            <!-- Workspace header -->
            <Border Grid.Row="0" Background="#1F3864">
                <TextBlock x:Name="TxtWsHeader" Text="Asset e Conformità"
                           Foreground="White" FontSize="12" FontWeight="SemiBold"
                           VerticalAlignment="Center" Margin="10,0"/>
            </Border>

            <!-- TreeView navigation -->
            <TreeView Grid.Row="1" x:Name="MainNavTree"
                      Background="White" BorderThickness="0,0,1,0"
                      BorderBrush="#D0D4DC" FontSize="12">
                <TreeView.Resources>
                    <Style TargetType="TreeViewItem">
                        <Setter Property="Padding"   Value="4,5"/>
                        <Setter Property="Foreground" Value="#1a1a1a"/>
                        <Setter Property="Background" Value="Transparent"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="TreeViewItem">
                                    <StackPanel>
                                        <Border x:Name="Bd" Background="Transparent"
                                                BorderBrush="Transparent" BorderThickness="1"
                                                Padding="{TemplateBinding Padding}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="16"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <ToggleButton x:Name="Expander" Grid.Column="0"
                                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                                              Background="Transparent" BorderThickness="0"
                                                              Focusable="False" Width="16" Height="16"
                                                              Padding="0" Cursor="Hand">
                                                    <ToggleButton.Template>
                                                        <ControlTemplate TargetType="ToggleButton">
                                                            <TextBlock x:Name="Arrow" Text="▶" FontSize="9"
                                                                       Foreground="#888888"
                                                                       HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"/>
                                                            <ControlTemplate.Triggers>
                                                                <Trigger Property="IsChecked" Value="True">
                                                                    <Setter TargetName="Arrow" Property="Text" Value="▼"/>
                                                                </Trigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </ToggleButton.Template>
                                                </ToggleButton>
                                                <ContentPresenter Grid.Column="1"
                                                                  ContentSource="Header"
                                                                  VerticalAlignment="Center"/>
                                            </Grid>
                                        </Border>
                                        <ItemsPresenter x:Name="ItemsHost" Margin="16,0,0,0"/>
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="False">
                                            <Setter TargetName="ItemsHost" Property="Visibility" Value="Collapsed"/>
                                        </Trigger>
                                        <Trigger Property="HasItems" Value="False">
                                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#CCE5FF"/>
                                            <Setter TargetName="Bd" Property="BorderBrush" Value="#99C3E8"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#EFF6FF"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </TreeView.Resources>

                <!-- Workspace: Asset e Conformità -->
                <TreeViewItem x:Name="TvGroupAsset" IsExpanded="True" Padding="4,4"
                              Header="🏠  Asset e Conformità">
                    <TreeViewItem Header="📡  Rete e Device"  Tag="0" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="🖥️  PC Gestiti"     Tag="4" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="🔐  Certificati"    Tag="1" Padding="4,3" Selected="NavTree_ItemSelected"/>
                </TreeViewItem>

                <!-- Workspace: Libreria Software -->
                <TreeViewItem x:Name="TvGroupSoftware" IsExpanded="True" Padding="4,4"
                              Header="📦  Libreria Software" Visibility="Collapsed">
                    <TreeViewItem Header="📦  Applicazioni"   Tag="2" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="⚙️  OPSI"           Tag="3" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="💿  Deploy OS"      Tag="5" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="⚙️  Workflow"       Tag="6" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="📜  Script Library" Tag="9" Padding="4,3" Selected="NavTree_ItemSelected"/>
                </TreeViewItem>

                <!-- Workspace: Monitoraggio -->
                <TreeViewItem x:Name="TvGroupMonitor" IsExpanded="True" Padding="4,4"
                              Header="📊  Monitoraggio" Visibility="Collapsed">
                    <TreeViewItem Header="📋  Richieste CR"   Tag="7" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="🖥️  Console SCCM"   Tag="8" Padding="4,3" Selected="NavTree_ItemSelected"/>
                </TreeViewItem>

                <!-- Workspace: Amministrazione -->
                <TreeViewItem x:Name="TvGroupAdmin" IsExpanded="True" Padding="4,4"
                              Header="⚙️  Amministrazione" Visibility="Collapsed">
                    <TreeViewItem Header="🖥️  Proxmox"        Tag="11" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="⚙️  Impostazioni"   Tag="13" Padding="4,3" Selected="NavTree_ItemSelected"/>
                    <TreeViewItem Header="ℹ️  About"           Tag="12" Padding="4,3" Selected="NavTree_ItemSelected"/>
                </TreeViewItem>
            </TreeView>

            <!-- Workspace switcher -->
            <Border Grid.Row="2" Background="#1F3864" BorderBrush="#0A1F40" BorderThickness="0,1,0,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Button x:Name="WsBtnAsset"    Content="Asset"    Tag="🏠" Style="{StaticResource WsBtnActive}" Width="52" Click="WsBtn_Click"/>
                    <Button x:Name="WsBtnSoftware" Content="Software" Tag="📦" Style="{StaticResource WsBtn}"       Width="52" Click="WsBtn_Click"/>
                    <Button x:Name="WsBtnMonitor"  Content="Monitor"  Tag="📊" Style="{StaticResource WsBtn}"       Width="52" Click="WsBtn_Click"/>
                    <Button x:Name="WsBtnAdmin"    Content="Admin"    Tag="⚙️" Style="{StaticResource WsBtn}"       Width="52" Click="WsBtn_Click"/>
                </StackPanel>
            </Border>

            <!-- Pulsanti nav nascosti (compatibilità codice) -->
            <StackPanel Visibility="Collapsed">
                <Button x:Name="NavRete"         Tag="0"  Click="Nav_Click"/>
                <Button x:Name="NavCert"         Tag="1"  Click="Nav_Click"/>
                <Button x:Name="NavApp"          Tag="2"  Click="Nav_Click"/>
                <Button x:Name="NavOpsi"         Tag="3"  Click="Nav_Click"/>
                <Button x:Name="NavPc"           Tag="4"  Click="Nav_Click"/>
                <Button x:Name="NavDeploy"       Tag="5"  Click="Nav_Click"/>
                <Button x:Name="NavWorkflow"     Tag="6"  Click="Nav_Click"/>
                <Button x:Name="NavRichieste"    Tag="7"  Click="Nav_Click"/>
                <Button x:Name="NavSccm"         Tag="8"  Click="Nav_Click"/>
                <Button x:Name="NavScript"       Tag="9"  Click="Nav_Click"/>
                <Button x:Name="NavImpostazioni" Tag="12" Click="Nav_Click"/>
                <Button x:Name="NavAbout"        Tag="11" Click="Nav_Click"/>
            </StackPanel>
        </Grid>

        <!-- ═══ TABS (headers nascosti, controllati dalla sidebar) ═══ -->
        <TabControl Background="#F4F6FA" BorderThickness="0"
                    x:Name="MainTabs"
                    SelectionChanged="MainTabs_SelectionChanged">
            <TabControl.Template>
                <ControlTemplate TargetType="TabControl">
                    <ContentPresenter ContentSource="SelectedContent"/>
                </ControlTemplate>
            </TabControl.Template>

            <!-- ─── TAB RETE ─── -->
            <TabItem Header="📡  Rete">
                <Grid Margin="16,12,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Barra scansione -->
                    <StackPanel Grid.Row="0" Margin="0,0,0,10">
                        <TextBlock Text="📡  Scansione rete" Style="{StaticResource SectionLabel}"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="TxtScanIp" Width="160" Margin="0,0,8,0"
                                     Style="{StaticResource SettingsBox}"
                                     Text="192.168.10.0" ToolTip="IP base della rete"/>
                            <TextBlock Text="/" Foreground="#64748b" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="16"/>
                            <TextBox x:Name="TxtScanSubnet" Width="60" Margin="0,0,12,0"
                                     Style="{StaticResource SettingsBox}"
                                     Text="24" ToolTip="Subnet mask (es: 24 = /24 = 254 host)"/>
                            <Button Content="▶  Scansiona" Style="{StaticResource BtnGreen}"
                                    x:Name="BtnScan" Click="BtnScan_Click"/>
                            <Button Content="🌐  Tutte le VLAN" Style="{StaticResource BtnBlue}"
                                    x:Name="BtnScanAll" Click="BtnScanAll_Click"
                                    ToolTip="Scansiona tutte le subnet configurate nelle Impostazioni"/>
                            <Button Content="⏹  Stop" Style="{StaticResource BtnRed}"
                                    x:Name="BtnStop" Click="BtnStop_Click" IsEnabled="False"/>
                            <Button x:Name="BtnToggleMap" Content="🗺  Mappa" Style="{StaticResource BtnBlue}"
                                    Click="BtnToggleMap_Click" Margin="16,0,0,0"
                                    ToolTip="Vista mappa rete visuale"/>
                            <Button x:Name="BtnToggleHeatmap" Content="⬛  Heatmap" Style="{StaticResource BtnBlue}"
                                    Click="BtnToggleHeatmap_Click"
                                    ToolTip="Vista heatmap — tutti i 254 IP della subnet colorati per stato"/>
                            <Button x:Name="BtnAutoScan" Content="⏰  Auto" Style="{StaticResource BtnAmber}"
                                    Click="BtnAutoScan_Click" Margin="16,0,0,0"
                                    ToolTip="Attiva scansione automatica ogni N minuti"/>
                            <ComboBox x:Name="CboAutoScanInterval" Width="70" Margin="4,0,0,0"
                                      SelectedIndex="1" VerticalAlignment="Center" FontSize="12">
                                <ComboBoxItem Content="5 min"/>
                                <ComboBoxItem Content="15 min"/>
                                <ComboBoxItem Content="30 min"/>
                                <ComboBoxItem Content="60 min"/>
                            </ComboBox>
                        </StackPanel>
                        <ProgressBar x:Name="ScanProgress" Height="4" Margin="0,8,0,0"
                                     Background="#DBEAFE" Foreground="#2563eb"
                                     BorderThickness="0" Minimum="0" Maximum="100" Value="0"/>
                        <TextBlock x:Name="TxtScanStatus" Foreground="#475569" FontSize="11"
                                   Margin="0,4,0,0" Text="Inserisci IP e subnet, poi clicca Scansiona"/>
                    </StackPanel>

                    <!-- Stat cards -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#3b82f6">
                            <StackPanel>
                                <TextBlock Text="10" FontSize="22" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Device totali" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#10b981">
                            <StackPanel>
                                <TextBlock Text="8" FontSize="22" FontWeight="Bold" Foreground="#10b981"/>
                                <TextBlock Text="Online" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#3b82f6">
                            <StackPanel>
                                <TextBlock Text="4" FontSize="22" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Con certificato" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#f59e0b">
                            <StackPanel>
                                <TextBlock Text="6" FontSize="22" FontWeight="Bold" Foreground="#f59e0b"/>
                                <TextBlock Text="Senza cert" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Tabella device / Mappa -->
                    <Grid Grid.Row="2">

                    <!-- RADAR SCAN -->
                    <Border x:Name="RadarPanel" Visibility="Collapsed"
                            Background="#040810" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Viewbox Stretch="Uniform">
                                <Canvas x:Name="RadarCanvas" Width="700" Height="480" Background="Transparent"/>
                            </Viewbox>
                            <TextBlock x:Name="TxtRadarStatus" HorizontalAlignment="Center"
                                       VerticalAlignment="Bottom" Margin="0,0,0,8"
                                       FontFamily="Consolas" FontSize="11"
                                       Foreground="#00dc50" Text="● SCANNING"/>
                        </Grid>
                    </Border>

                    <!-- Mappa rete visuale -->
                    <Border x:Name="MapPanel" Visibility="Collapsed"
                            Background="#0a0f1e" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Canvas x:Name="NetMapCanvas" Width="900" Height="600"
                                        Background="Transparent" Margin="20"/>
                            </ScrollViewer>
                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top" Margin="12,8" Orientation="Horizontal">
                                <Ellipse Width="10" Height="10" Fill="#10b981" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Online" Foreground="#64748b" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Ellipse Width="10" Height="10" Fill="#ef4444" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Offline" Foreground="#64748b" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Ellipse Width="10" Height="10" Fill="#f59e0b" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Gateway" Foreground="#64748b" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Heatmap subnet -->
                    <Border x:Name="HeatmapPanel" Visibility="Collapsed"
                            Background="#06080f" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                                <Canvas x:Name="HeatmapCanvas" Width="900" Height="540"
                                        Background="Transparent" Margin="16,12"/>
                            </ScrollViewer>
                            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Margin="20,10" Orientation="Horizontal">
                                <Rectangle Width="12" Height="12" Fill="#10b981" Margin="0,0,5,0"/>
                                <TextBlock Text="Online" Foreground="#64748b" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Rectangle Width="12" Height="12" Fill="#3b82f6" Margin="0,0,5,0"/>
                                <TextBlock Text="Ha certificato" Foreground="#64748b" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Rectangle Width="12" Height="12" Fill="#f59e0b" Margin="0,0,5,0"/>
                                <TextBlock Text="Gateway" Foreground="#64748b" FontSize="10" VerticalAlignment="Center" Margin="0,0,14,0"/>
                                <Rectangle Width="12" Height="12" Fill="#1e2a40" Margin="0,0,5,0"/>
                                <TextBlock Text="Offline / sconosciuto" Foreground="#64748b" FontSize="10" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Traceroute panel -->
                    <Border x:Name="TraceroutePanel" Visibility="Collapsed"
                            Background="#06080f" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,10,12,6">
                                <TextBlock x:Name="TxtTracerouteTitle" Text="🔀  Traceroute"
                                           Foreground="#60a5fa" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <Button Content="✕ Chiudi" Margin="16,0,0,0" Padding="8,3"
                                        Background="Transparent" BorderBrush="#334155"
                                        Foreground="#94a3b8" FontSize="11" Cursor="Hand"
                                        Click="BtnCloseTraceroute_Click"/>
                            </StackPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="TracerouteStack" Margin="12,0,12,12"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Speed test panel -->
                    <Border x:Name="SpeedTestPanel" Visibility="Collapsed"
                            Background="#06080f" CornerRadius="6" ClipToBounds="True">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,10,12,6">
                                <TextBlock Text="⚡  Speed Test" Foreground="#fbbf24"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <Button Content="✕ Chiudi" Margin="16,0,0,0" Padding="8,3"
                                        Background="Transparent" BorderBrush="#334155"
                                        Foreground="#94a3b8" FontSize="11" Cursor="Hand"
                                        Click="BtnCloseSpeedTest_Click"/>
                            </StackPanel>
                            <Grid Grid.Row="1" Margin="20,10,20,20">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                    <TextBlock Text="⬇ DOWNLOAD" Foreground="#94a3b8" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Canvas x:Name="SpeedGaugeDown" Width="140" Height="140"/>
                                    <TextBlock x:Name="TxtSpeedDown" Text="— Mbps"
                                               Foreground="#4ade80" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock x:Name="TxtSpeedStatus" Text="Clicca ⚡ Speed Test\nper avviare"
                                               Foreground="#64748b" FontSize="12" TextAlignment="Center"
                                               TextWrapping="Wrap" HorizontalAlignment="Center"/>
                                    <TextBlock x:Name="TxtSpeedPing" Text="Ping: — ms"
                                               Foreground="#60a5fa" FontSize="13" FontWeight="SemiBold"
                                               HorizontalAlignment="Center" Margin="0,12,0,0"/>
                                </StackPanel>
                                <StackPanel Grid.Column="2" HorizontalAlignment="Center">
                                    <TextBlock Text="⬆ UPLOAD" Foreground="#94a3b8" FontSize="11"
                                               HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                    <Canvas x:Name="SpeedGaugeUp" Width="140" Height="140"/>
                                    <TextBlock x:Name="TxtSpeedUp" Text="— Mbps"
                                               Foreground="#60a5fa" FontSize="18" FontWeight="Bold"
                                               HorizontalAlignment="Center" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Change Log panel -->
                    <Border x:Name="ChangeLogPanel" Visibility="Collapsed"
                            Background="#0f172a" CornerRadius="6" MaxHeight="220">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="12,8,12,4">
                                <TextBlock Text="📋  Modifiche rilevate" Foreground="#fbbf24"
                                           FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtChangeLogTime" Foreground="#64748b"
                                           FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                                <Button Content="✕ Chiudi" Margin="16,0,0,0" Padding="8,3"
                                        Background="Transparent" BorderBrush="#334155"
                                        Foreground="#94a3b8" FontSize="11" Cursor="Hand"
                                        Click="BtnCloseChangeLog_Click"/>
                            </StackPanel>
                            <TextBox Grid.Row="1" x:Name="TxtChangeLog"
                                     Background="Transparent" Foreground="#e2e8f0"
                                     BorderThickness="0" FontFamily="Consolas" FontSize="12"
                                     IsReadOnly="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="12,4,12,10"/>
                        </Grid>
                    </Border>

                    <!-- Tabella device -->
                    <DataGrid x:Name="NetGrid" SelectionMode="Extended"
                              MouseDoubleClick="NetGrid_DoubleClick"
                              SelectionChanged="NetGrid_SelectionChanged"
                              ToolTip="Doppio click per dettagli e scansione porte">
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="📋  Copia IP"       Click="MenuCopyIp_Click"/>
                                <MenuItem Header="📋  Copia MAC"      Click="MenuCopyMac_Click"/>
                                <MenuItem Header="📋  Copia IP + MAC" Click="MenuCopyBoth_Click"/>
                                <Separator/>
                                <MenuItem Header="🔍  Dettagli porte"  Click="MenuDetails_Click"/>
                                <MenuItem Header="💡  Wake-on-LAN"     Click="MenuWoL_Click"        ToolTip="Invia magic packet UDP per accendere il PC"/>
                                <MenuItem Header="🖥️  SSH Terminal"    Click="MenuSsh_Click"        ToolTip="Apre terminale SSH verso questo device"/>
                                <MenuItem Header="🔀  Traceroute"      Click="MenuTraceroute_Click" ToolTip="Visualizza il percorso verso questo IP"/>
                                <Separator/>
                                <MenuItem Header="📤  Esporta CSV"     Click="MenuExportCsv_Click"  ToolTip="Esporta tutti i device in formato CSV"/>
                                <Separator/>
                                <MenuItem Header="📝  Aggiungi nota"   Click="MenuAddNote_Click"    ToolTip="Aggiungi nota personalizzata a questo device"/>
                                <MenuItem Header="🏷️  Tag device"     Click="MenuTagDevice_Click"  ToolTip="Assegna tag personalizzato (es: server, stampante, iot)"/>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=" "        Binding="{Binding Icon}"           Width="36"/>
                            <DataGridTextColumn Header="IP"       Binding="{Binding Ip}"             Width="120"/>
                            <DataGridTextColumn Header="MAC"      Binding="{Binding Mac}"            Width="140"/>
                            <DataGridTextColumn Header="Hostname" Binding="{Binding Name}"           Width="130"/>
                            <DataGridTextColumn Header="Tipo"     Binding="{Binding DeviceType}"     Width="110"/>
                            <DataGridTextColumn Header="Conn."    Binding="{Binding ConnectionType}" Width="110"/>
                            <DataGridTextColumn Header="Vendor"   Binding="{Binding Vendor}"         Width="100"/>
                            <DataGridTextColumn Header="Cert"     Binding="{Binding CertStatus}"     Width="70"/>
                            <DataGridTextColumn Header="Stato"    Binding="{Binding Status}"         Width="80"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    </Grid>

                    <!-- Live ping panel -->
                    <Border x:Name="PingPanel" Grid.Row="3" Visibility="Collapsed"
                            Background="#0a0f1e" CornerRadius="6" Margin="0,0,0,4" Height="130">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <Canvas x:Name="PingCanvas" Grid.Column="0" Margin="8,8,4,8"
                                    ClipToBounds="True" Background="Transparent"/>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                <TextBlock x:Name="TxtPingHost" Text="—" Foreground="#60a5fa"
                                           FontSize="11" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                <TextBlock x:Name="TxtPingLast" Text="— ms" Foreground="#10b981"
                                           FontSize="22" FontWeight="Bold" Margin="0,4,0,0"/>
                                <TextBlock x:Name="TxtPingAvg"  Text="avg: — ms" Foreground="#94a3b8" FontSize="10"/>
                                <TextBlock x:Name="TxtPingMin"  Text="min: — ms" Foreground="#34d399" FontSize="10"/>
                                <TextBlock x:Name="TxtPingMax"  Text="max: — ms" Foreground="#f87171" FontSize="10"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Azioni -->
                    <StackPanel Grid.Row="4" Orientation="Horizontal" Margin="0,10,0,12">
                        <Button Content="➕  Registra" Style="{StaticResource BtnGreen}"
                                Click="BtnRegisterDevices_Click"
                                ToolTip="Registra i device selezionati (via MAC) per App e OPSI"/>
                        <Button Content="🔐  Genera Cert" Style="{StaticResource BtnBlue}"
                                Click="BtnGenerateCert_Click"/>
                        <Button Content="📱  QR Code" Style="{StaticResource BtnBlue}"
                                Click="BtnQrNet_Click"/>
                        <Button x:Name="BtnMonitor" Content="👁  Monitora" Style="{StaticResource BtnAmber}"
                                Click="BtnMonitor_Click"
                                ToolTip="Scansione continua ogni 30s — notifica nuovi device o disconnessioni"/>
                        <Button Content="📊  Inventario" Style="{StaticResource BtnBlue}"
                                Click="BtnInventory_Click"
                                ToolTip="Apre inventario hardware/software per il device selezionato"/>
                        <Button Content="💡  WoL" Style="{StaticResource BtnAmber}"
                                Click="BtnWoL_Click"
                                ToolTip="Wake-on-LAN — accende il PC selezionato via magic packet"/>
                        <Button Content="🔍  mDNS" Style="{StaticResource BtnBlue}"
                                Click="BtnMdns_Click"
                                ToolTip="Scopri device via mDNS/Bonjour (stampanti, Apple, Chromecast...)"/>
                        <Button Content="⚡  Speed Test" Style="{StaticResource BtnBlue}"
                                Click="BtnSpeedTest_Click"
                                ToolTip="Testa la velocità della connessione internet"/>
                        <Button Content="📤  Esporta CSV" Style="{StaticResource BtnBlue}"
                                Click="BtnExportCsv_Click"
                                ToolTip="Esporta la lista device in formato CSV"/>
                        <Button Content="📊  Report HTML" Style="{StaticResource BtnBlue}"
                                Click="BtnExportHtml_Click"
                                ToolTip="Genera report HTML della rete (si apre nel browser)"/>
                        <TextBlock VerticalAlignment="Center" Margin="12,0,0,0"
                                   Foreground="#475569" FontSize="11"
                                   Text="Doppio click per porte  •  Ctrl+click multi-selezione"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB CERTIFICATI ─── -->
            <TabItem Header="🔐  Certificati">
                <Grid Margin="16,12,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🔐  Certificati WiFi EAP-TLS — PolarisCore Secure"
                               Style="{StaticResource SectionLabel}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#10b981">
                            <StackPanel>
                                <TextBlock Text="4" FontSize="22" FontWeight="Bold" Foreground="#10b981"/>
                                <TextBlock Text="Attivi" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#ef4444">
                            <StackPanel>
                                <TextBlock Text="1" FontSize="22" FontWeight="Bold" Foreground="#ef4444"/>
                                <TextBlock Text="Revocati" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#3b82f6">
                            <StackPanel>
                                <TextBlock Text="5" FontSize="22" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Totali" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#60a5fa">
                            <StackPanel>
                                <TextBlock Text="2036" FontSize="22" FontWeight="Bold" Foreground="#60a5fa"/>
                                <TextBlock Text="Scad. minima" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="CertGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=" "       Binding="{Binding Icon}"    Width="36"/>
                            <DataGridTextColumn Header="Device"  Binding="{Binding Name}"    Width="140"/>
                            <DataGridTextColumn Header="MAC"     Binding="{Binding Mac}"     Width="150"/>
                            <DataGridTextColumn Header="Creato"  Binding="{Binding Created}" Width="110"/>
                            <DataGridTextColumn Header="Scade"   Binding="{Binding Expires}" Width="110"/>
                            <DataGridTextColumn Header="Stato"   Binding="{Binding Status}"  Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,12">
                        <Button Content="✨  Nuovo"    Style="{StaticResource BtnGreen}" Click="BtnNewCert_Click"/>
                        <Button Content="📱  QR Code"  Style="{StaticResource BtnBlue}"  Click="BtnQrCert_Click"/>
                        <Button Content="❌  Revoca"   Style="{StaticResource BtnRed}"   Click="BtnRevoke_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB APP ─── -->
            <TabItem Header="📦  App">
                <Grid Margin="16,12,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📦  Portale Software — installazioni remote sui PC"
                               Style="{StaticResource SectionLabel}"/>

                    <!-- Coda -->
                    <StackPanel Grid.Row="1">
                        <TextBlock Text="Code attive" Foreground="#1D4ED8" FontSize="12" FontWeight="SemiBold" Margin="0,0,0,6"/>
                        <DataGrid x:Name="AppQueueGrid" MaxHeight="130">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="PC"           Binding="{Binding Pc}"     Width="140"/>
                                <DataGridTextColumn Header="IP"           Binding="{Binding Ip}"     Width="120"/>
                                <DataGridTextColumn Header="MAC"          Binding="{Binding Mac}"    Width="145"/>
                                <DataGridTextColumn Header="App in coda"  Binding="{Binding Apps}"   Width="180"/>
                                <DataGridTextColumn Header="Stato"        Binding="{Binding Status}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </StackPanel>

                    <!-- Catalogo -->
                    <ScrollViewer Grid.Row="2" Margin="0,12,0,0" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="SvPanel_PreviewMouseWheel">
                        <StackPanel>
                            <TextBlock Text="Catalogo App" Foreground="#60a5fa" FontSize="12"
                                       FontWeight="SemiBold" Margin="0,0,0,8"/>
                            <ItemsControl x:Name="AppCatalog">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,10">
                                            <TextBlock Text="{Binding Category}" Foreground="#a78bfa"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding Items}" Foreground="#64748b"
                                                       Margin="12,2,0,0" FontSize="12"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,12">
                        <Button Content="▶  Installa su PC..." Style="{StaticResource BtnGreen}" Click="BtnInstallApp_Click"/>
                        <Button Content="📤  Upload custom"    Style="{StaticResource BtnBlue}"  Click="BtnUploadApp_Click"/>
                        <Button Content="🗑  Svuota coda"      Style="{StaticResource BtnRed}"   Click="BtnClearQueue_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB OPSI ─── -->
            <TabItem Header="⚙️  OPSI">
                <Grid Margin="16,12,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="⚙️  OPSI — Pacchetti software gestiti"
                               Style="{StaticResource SectionLabel}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#10b981">
                            <StackPanel>
                                <TextBlock Text="4" FontSize="22" FontWeight="Bold" Foreground="#10b981"/>
                                <TextBlock Text="Aggiornati" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#f59e0b">
                            <StackPanel>
                                <TextBlock Text="1" FontSize="22" FontWeight="Bold" Foreground="#f59e0b"/>
                                <TextBlock Text="Da aggiornare" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#3b82f6">
                            <StackPanel>
                                <TextBlock Text="5" FontSize="22" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Totali" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#60a5fa">
                            <StackPanel>
                                <TextBlock Text="2026-03-04" FontSize="18" FontWeight="Bold" Foreground="#60a5fa"/>
                                <TextBlock Text="Ultimo deploy" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <DataGrid Grid.Row="2" x:Name="OpsiGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Pacchetto"   Binding="{Binding Name}"    Width="200"/>
                            <DataGridTextColumn Header="Versione"    Binding="{Binding Version}" Width="100"/>
                            <DataGridTextColumn Header="Stato"       Binding="{Binding Status}"  Width="130"/>
                            <DataGridTextColumn Header="Aggiornato"  Binding="{Binding Updated}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,12">
                        <Button Content="🚀  Crea pacchetto" Style="{StaticResource BtnGreen}" Click="BtnOpsiCreate_Click"/>
                        <Button Content="⬆  Aggiorna"        Style="{StaticResource BtnAmber}" Click="BtnOpsiUpdate_Click"/>
                        <Button Content="🗑  Elimina"         Style="{StaticResource BtnRed}"   Click="BtnOpsiDelete_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB PC ─── -->
            <TabItem Header="🖥️  PC">
                <Grid Margin="16,12,16,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🖥️  PC — Stato agenti e risorse di sistema"
                               Style="{StaticResource SectionLabel}"/>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#10b981">
                            <StackPanel>
                                <TextBlock Text="3" FontSize="22" FontWeight="Bold" Foreground="#10b981"/>
                                <TextBlock Text="Online" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#ef4444">
                            <StackPanel>
                                <TextBlock Text="1" FontSize="22" FontWeight="Bold" Foreground="#ef4444"/>
                                <TextBlock Text="Offline" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#3b82f6">
                            <StackPanel>
                                <TextBlock Text="4" FontSize="22" FontWeight="Bold" Foreground="#1D4ED8"/>
                                <TextBlock Text="Totali" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}" BorderThickness="4,1,1,1" BorderBrush="#60a5fa">
                            <StackPanel>
                                <TextBlock Text="4" FontSize="22" FontWeight="Bold" Foreground="#60a5fa"/>
                                <TextBlock Text="Agent installato" Foreground="#64748b" FontSize="11"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Gauge sistema locale -->
                    <Border Grid.Row="1" Background="#06080f" CornerRadius="6"
                            Margin="0,0,0,12" Padding="0,8" Height="110"
                            VerticalAlignment="Bottom">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Canvas x:Name="GaugeCpu"  Grid.Column="0" ClipToBounds="True"/>
                            <Canvas x:Name="GaugeRam"  Grid.Column="1" ClipToBounds="True"/>
                            <Canvas x:Name="GaugeDisk" Grid.Column="2" ClipToBounds="True"/>
                            <Canvas x:Name="GaugeNet"  Grid.Column="3" ClipToBounds="True"/>
                        </Grid>
                    </Border>

                    <DataGrid Grid.Row="2" x:Name="PcGrid">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header=" "       Binding="{Binding Icon}"   Width="36"/>
                            <DataGridTextColumn Header="Nome"    Binding="{Binding Name}"   Width="140"/>
                            <DataGridTextColumn Header="IP"      Binding="{Binding Ip}"     Width="130"/>
                            <DataGridTextColumn Header="OS"      Binding="{Binding Os}"     Width="110"/>
                            <DataGridTextColumn Header="CPU"     Binding="{Binding Cpu}"    Width="70"/>
                            <DataGridTextColumn Header="RAM"     Binding="{Binding Ram}"    Width="100"/>
                            <DataGridTextColumn Header="Stato"   Binding="{Binding Status}" Width="90"/>
                            <DataGridTextColumn Header="Agent"   Binding="{Binding Agent}"  Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,10,0,12">
                        <Button Content="📊  Inventario"      Style="{StaticResource BtnAmber}" Click="BtnInventory_Click"
                                ToolTip="Raccoglie hardware, OS e software installati via WMI"/>
                        <Button Content="🖥️  RDP"             Style="{StaticResource BtnGreen}" Click="BtnRdp_Click"/>
                        <Button Content="📜  Esegui script"   Style="{StaticResource BtnBlue}"  Click="BtnRunScript_Click"/>
                        <Button Content="🔄  Aggiorna agent"  Style="{StaticResource BtnBlue}"  Click="BtnUpdateAgent_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

            <!-- ─── TAB DEPLOY ─── -->
            <TabItem Header="💿  Deploy">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390" MinWidth="260"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                    </Grid.ColumnDefinitions>

                    <!-- Splitter ridimensionabile -->
                    <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                  Background="#D0D5DC" ShowsPreview="False"/>

                    <!-- COLONNA SX: Form configurazione -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                  Margin="16,12,12,12"
                                  PreviewMouseWheel="SvPanel_PreviewMouseWheel">
                        <StackPanel>
                            <TextBlock Text="💿  Crea installazione Windows automatica"
                                       Style="{StaticResource SectionLabel}"/>

                            <!-- 🪟 Windows -->
                            <TextBlock Text="🪟  Windows" Style="{StaticResource GroupTitle}"/>

                            <TextBlock Text="Edizione" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="CboWinEdition" Width="330" HorizontalAlignment="Left"
                                      Background="White" Foreground="#1a1a1a" BorderBrush="#C8CDD5"
                                      FontSize="13" Padding="8,5">
                                <!-- Client -->
                                <ComboBoxItem Content="── Client ──"            IsEnabled="False" Foreground="#475569"/>
                                <ComboBoxItem Content="Windows 11 Pro"          Tag="Professional"            IsSelected="True"/>
                                <ComboBoxItem Content="Windows 11 Home"         Tag="Home"/>
                                <ComboBoxItem Content="Windows 11 Enterprise"   Tag="Enterprise"/>
                                <ComboBoxItem Content="Windows 10 Pro"          Tag="Professional"/>
                                <ComboBoxItem Content="Windows 10 Enterprise"   Tag="Enterprise"/>
                                <!-- Server -->
                                <ComboBoxItem Content="── Server ──"            IsEnabled="False" Foreground="#475569"/>
                                <ComboBoxItem Content="Windows Server 2025 Standard"    Tag="Windows Server 2025 Standard"/>
                                <ComboBoxItem Content="Windows Server 2025 Datacenter"  Tag="Windows Server 2025 Datacenter"/>
                                <ComboBoxItem Content="Windows Server 2022 Standard"    Tag="Windows Server 2022 Standard"/>
                                <ComboBoxItem Content="Windows Server 2022 Datacenter"  Tag="Windows Server 2022 Datacenter"/>
                                <ComboBoxItem Content="Windows Server 2019 Standard"    Tag="Windows Server 2019 Standard"/>
                            </ComboBox>

                            <TextBlock Text="Nome PC (template)" Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="TxtDeployPcName" Style="{StaticResource SettingsBox}"
                                     Width="330" Text="PC-{MAC6}"
                                     ToolTip="Variabili: {MAC6}=ultimi 6 hex del MAC, testo fisso"/>
                            <TextBlock Text="es: PC-{MAC6} → PC-B3CEEB   |   UFFICIO-01 (fisso)"
                                       Foreground="#475569" FontSize="10" Margin="0,2,0,0"/>

                            <TextBlock Text="Lingua sistema" Style="{StaticResource SettingsLabel}"/>
                            <ComboBox x:Name="CboWinLocale" Width="330" HorizontalAlignment="Left"
                                      Background="White" Foreground="#1a1a1a" BorderBrush="#C8CDD5"
                                      FontSize="13" Padding="8,5">
                                <ComboBoxItem Content="it-IT — Italiano (Italia)"       Tag="it-IT" IsSelected="True"/>
                                <ComboBoxItem Content="en-US — English (United States)" Tag="en-US"/>
                                <ComboBoxItem Content="en-GB — English (United Kingdom)" Tag="en-GB"/>
                                <ComboBoxItem Content="fr-FR — Français (France)"       Tag="fr-FR"/>
                                <ComboBoxItem Content="de-DE — Deutsch (Deutschland)"   Tag="de-DE"/>
                            </ComboBox>

                            <!-- 👤 Account -->
                            <TextBlock Text="👤  Account" Style="{StaticResource GroupTitle}"/>

                            <TextBlock Text="Licenza Windows / Product Key (opzionale)"
                                       Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="TxtDeployProductKey" Style="{StaticResource SettingsBox}"
                                     Width="330" FontFamily="Consolas"
                                     ToolTip="Es: XXXXX-XXXXX-XXXXX-XXXXX-XXXXX — lascia vuoto per KMS/valutazione"/>
                            <TextBlock Text="Vuoto = KMS volume licensing o Windows di valutazione (180gg)"
                                       Foreground="#475569" FontSize="10" Margin="0,2,0,0"/>

                            <!-- Tipo account -->
                            <TextBlock Text="Tipo account principale" Style="{StaticResource SettingsLabel}"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <RadioButton x:Name="RbLocalAccount" Content="👤  Account locale (automatico)"
                                             Foreground="#333333" IsChecked="True" Margin="0,0,16,0"
                                             GroupName="AccountType"
                                             Checked="RbAccount_Checked"
                                             ToolTip="Installazione 100% automatica, nessuna interazione"/>
                                <RadioButton x:Name="RbMsAccount"   Content="☁️  Account Microsoft"
                                             Foreground="#333333" GroupName="AccountType"
                                             Checked="RbAccount_Checked"
                                             ToolTip="Il setup si fermerà alla schermata Microsoft account — l'utente fa login manualmente"/>
                            </StackPanel>
                            <TextBlock x:Name="TxtAccountNote"
                                       Text="⚠️  Con account Microsoft il setup si ferma e chiede login — poi il post-install riparte automaticamente"
                                       Foreground="#f59e0b" FontSize="10" Margin="0,4,0,0"
                                       TextWrapping="Wrap" Visibility="Collapsed"/>

                            <TextBlock Text="Password Amministratore locale" Style="{StaticResource SettingsLabel}"/>
                            <PasswordBox x:Name="TxtDeployAdminPass" Style="{StaticResource SettingsPass}"
                                         Width="330"/>

                            <TextBlock Text="Utente locale aggiuntivo (opzionale — lascia vuoto per saltare)"
                                       Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="TxtDeployUsername" Style="{StaticResource SettingsBox}"
                                     Width="330" ToolTip="Lascia vuoto per non creare utente aggiuntivo"/>

                            <TextBlock Text="Password utente standard" Style="{StaticResource SettingsLabel}"/>
                            <PasswordBox x:Name="TxtDeployUserPass" Style="{StaticResource SettingsPass}"
                                         Width="330"/>

                            <!-- 🏢 Dominio -->
                            <TextBlock Text="🏢  Dominio / Join" Style="{StaticResource GroupTitle}"/>

                            <StackPanel Orientation="Horizontal" Margin="0,4,0,8">
                                <RadioButton x:Name="RbWorkgroup" Content="Workgroup"
                                             Foreground="#333333" IsChecked="True" Margin="0,0,16,0"
                                             GroupName="DomainType" Checked="RbDomain_Checked"/>
                                <RadioButton x:Name="RbAdLocale" Content="AD locale"
                                             Foreground="#333333" Margin="0,0,16,0"
                                             GroupName="DomainType" Checked="RbDomain_Checked"/>
                                <RadioButton x:Name="RbAzureAd" Content="Azure AD"
                                             Foreground="#333333"
                                             GroupName="DomainType" Checked="RbDomain_Checked"/>
                            </StackPanel>

                            <!-- Pannello AD locale -->
                            <StackPanel x:Name="PanelAdLocale" Visibility="Collapsed">
                                <TextBlock Text="Nome dominio" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="TxtDomainName" Style="{StaticResource SettingsBox}"
                                         Width="330" ToolTip="Es: azienda.local oppure azienda.com"/>

                                <TextBlock Text="Utente con permessi di join" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="TxtDomainUser" Style="{StaticResource SettingsBox}"
                                         Width="330" ToolTip="Es: Administrator oppure join-account"/>

                                <TextBlock Text="Password utente di join" Style="{StaticResource SettingsLabel}"/>
                                <PasswordBox x:Name="TxtDomainPass" Style="{StaticResource SettingsPass}"
                                             Width="330"/>

                                <TextBlock Text="IP Domain Controller (DNS)" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="TxtDomainControllerIp" Style="{StaticResource SettingsBox}"
                                         Width="330" ToolTip="IP del DC — necessario per risolvere il dominio durante l'installazione"/>

                                <TextBlock Text="✅  Unione al dominio completamente automatica (pass specialize)"
                                           Foreground="#4ade80" FontSize="10" Margin="0,3,0,0"/>
                            </StackPanel>

                            <!-- Pannello Azure AD -->
                            <StackPanel x:Name="PanelAzureAd" Visibility="Collapsed">
                                <TextBlock Text="Tenant ID (opzionale)" Style="{StaticResource SettingsLabel}"/>
                                <TextBox x:Name="TxtAzureTenant" Style="{StaticResource SettingsBox}"
                                         Width="330" FontFamily="Consolas"
                                         ToolTip="GUID del tenant Azure AD — lascia vuoto per tenant automatico"/>
                                <TextBlock Foreground="#f59e0b" FontSize="10" Margin="0,3,0,8"
                                           TextWrapping="Wrap"
                                           Text="⚠️  Azure AD join viene avviato dal postinstall (dsregcmd). L'utente dovrà fare login con il proprio account Microsoft 365 al primo avvio."/>
                            </StackPanel>

                            <!-- 📦 Software -->
                            <TextBlock Text="📦  Software (winget)" Style="{StaticResource GroupTitle}"/>

                            <!-- Lista dinamica pacchetti -->
                            <ListBox x:Name="LstPackages"
                                     Background="White" BorderBrush="#C8CDD5" BorderThickness="1"
                                     Width="330" Height="160" HorizontalAlignment="Left"
                                     Margin="0,0,0,6" Padding="0">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding"    Value="6,3"/>
                                        <Setter Property="Foreground" Value="#222222"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding}"
                                                       FontFamily="Consolas" FontSize="12"
                                                       VerticalAlignment="Center"/>
                                            <Button Grid.Column="1" Content="✕"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#ef4444" FontSize="11" Padding="4,0"
                                                    Cursor="Hand"
                                                    Click="BtnRemovePackage_Click"
                                                    ToolTip="Rimuovi"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Aggiungi pacchetto -->
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,0">
                                <TextBox x:Name="TxtNewPackage"
                                         Background="White" Foreground="#1a1a1a" BorderBrush="#C8CDD5"
                                         Padding="8,5" FontFamily="Consolas" FontSize="12"
                                         Width="272"
                                         ToolTip="Winget ID esatto — es: Git.Git, Valve.Steam, Python.Python.3"
                                         KeyDown="TxtNewPackage_KeyDown"/>
                                <Button Content="➕" Style="{StaticResource BtnGreen}"
                                        Padding="10,5" Margin="4,0,0,0"
                                        Click="BtnAddPackage_Click" ToolTip="Aggiungi pacchetto"/>
                            </StackPanel>
                            <TextBlock Text="Winget ID — es: Git.Git  |  Valve.Steam  |  Python.Python.3"
                                       Foreground="#475569" FontSize="10" Margin="0,3,0,0"/>

                            <!-- 🔒 Agent -->
                            <TextBlock Text="🔒  NovaSCM Agent" Style="{StaticResource GroupTitle}"/>

                            <CheckBox x:Name="ChkIncludeAgent"
                                      Content="Includi agente enrollment WiFi EAP-TLS"
                                      Foreground="#333333" IsChecked="True" Margin="0,4,0,8"/>

                            <TextBlock Text="URL server NovaSCM (per l'agente)"
                                       Style="{StaticResource SettingsLabel}"/>
                            <TextBox x:Name="TxtDeployServerUrl" Style="{StaticResource SettingsBox}"
                                     Width="330"
                                     ToolTip="Es: http://192.168.20.110:9090"/>

                            <!-- Profili -->
                            <TextBlock Text="💾  Profili" Style="{StaticResource GroupTitle}"/>
                            <ComboBox x:Name="CboProfiles" Width="330" HorizontalAlignment="Left"
                                      Background="#0d1b3e" Foreground="#e2e8f0" BorderBrush="#1e3a5f"
                                      FontSize="13" Padding="8,5" Margin="0,0,0,6"
                                      ToolTip="Seleziona un profilo salvato"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                <Button Content="📂  Carica"  Style="{StaticResource BtnBlue}"
                                        Padding="10,5" Click="BtnLoadProfile_Click"
                                        ToolTip="Carica profilo selezionato"/>
                                <Button Content="💾  Salva"   Style="{StaticResource BtnGreen}"
                                        Padding="10,5" Click="BtnSaveProfile_Click"
                                        ToolTip="Salva configurazione corrente"/>
                                <Button Content="📁  Importa" Style="{StaticResource BtnAmber}"
                                        Padding="10,5" Click="BtnImportProfile_Click"
                                        ToolTip="Importa profilo da file JSON"/>
                                <Button Content="🗑" Style="{StaticResource BtnRed}"
                                        Padding="10,5" Click="BtnDeleteProfile_Click"
                                        ToolTip="Elimina profilo selezionato"/>
                            </StackPanel>

                            <!-- Azioni -->
                            <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                <Button Content="⚙️  Genera file" Style="{StaticResource BtnGreen}"
                                        Click="BtnDeployGenerate_Click"/>
                                <Button Content="💾  Salva cartella" Style="{StaticResource BtnBlue}"
                                        x:Name="BtnDeploySave" IsEnabled="False"
                                        Click="BtnDeploySave_Click"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                <Button Content="🖴  Scrivi USB" Style="{StaticResource BtnAmber}"
                                        x:Name="BtnDeployUsb" IsEnabled="False"
                                        Click="BtnDeployUsb_Click"
                                        ToolTip="Copia file nella radice di una USB"/>
                                <Button Content="🌐  Deploy PXE" Style="{StaticResource BtnBlue}"
                                        x:Name="BtnDeployPxe" IsEnabled="False"
                                        Click="BtnDeployPxe_Click"
                                        ToolTip="Copia su server PXE via SCP (CT 110)"/>
                            </StackPanel>

                            <TextBlock x:Name="TxtDeployStatus" Foreground="#10b981"
                                       FontSize="11" Margin="0,10,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- COLONNA DX: Preview XML -->
                    <Grid Grid.Column="2" Margin="0,12,16,12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="📄  Anteprima autounattend.xml"
                                   Foreground="#1D4ED8" FontSize="13" FontWeight="SemiBold"
                                   Margin="0,0,0,8"/>
                        <TextBox Grid.Row="1" x:Name="TxtDeployPreview"
                                 Background="#0a0f1e" Foreground="#4ade80"
                                 BorderBrush="#1e3a5f" BorderThickness="1"
                                 FontFamily="Consolas" FontSize="11"
                                 IsReadOnly="True" TextWrapping="NoWrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 Padding="12"/>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── TAB WORKFLOW ─── -->
            <TabItem Header="⚙️  Workflow">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>  <!-- toolbar principale -->
                        <RowDefinition Height="*"/>     <!-- contenuto -->
                        <RowDefinition Height="Auto"/>  <!-- status bar -->
                    </Grid.RowDefinitions>

                    <!-- Toolbar -->
                    <Border Grid.Row="0" Background="#EDF0F5" Padding="8,6">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="+ Nuovo Workflow"   Style="{StaticResource BtnGreen}"  Click="BtnWfNew_Click"/>
                            <Button Content="✏️ Rinomina"         Style="{StaticResource BtnBlue}"   Click="BtnWfRename_Click"/>
                            <Button Content="🗑 Elimina"          Style="{StaticResource BtnRed}"    Click="BtnWfDelete_Click"/>
                            <Separator Width="16" Background="Transparent"/>
                            <Button Content="↻ Aggiorna"          Style="{StaticResource BtnBlue}"   Click="BtnWfRefresh_Click"/>
                        </StackPanel>
                    </Border>

                    <!-- Contenuto: lista workflow | step + assegnazioni -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="260"/>
                            <ColumnDefinition Width="4"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- ─ COLONNA SINISTRA: lista workflow ─ -->
                        <Grid Grid.Column="0" Background="#F0F2F7">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Workflow definiti"
                                       Foreground="#1D4ED8" FontWeight="SemiBold"
                                       Padding="10,8,10,6" FontSize="12"/>
                            <ListBox x:Name="LstWorkflows" Grid.Row="1"
                                     Background="Transparent" BorderThickness="0"
                                     Foreground="#222222" FontSize="13"
                                     SelectionChanged="LstWorkflows_SelectionChanged">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="4,4,4,4">
                                            <TextBlock Text="{Binding Nome}" FontWeight="SemiBold"/>
                                            <TextBlock FontSize="11" Foreground="#64748b">
                                                <Run Text="v"/><Run Text="{Binding Versione}"/>
                                                <Run Text=" — "/><Run Text="{Binding StepCount}"/>
                                                <Run Text=" step"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="8,4"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Foreground" Value="#222222"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#DBEAFE"/>
                                                <Setter Property="Foreground" Value="#1E3A8A"/>
                                            </Trigger>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#EFF6FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                            </ListBox>
                        </Grid>

                        <!-- Splitter verticale -->
                        <GridSplitter Grid.Column="1" Width="4"
                                      HorizontalAlignment="Stretch"
                                      Background="#D0D5DC"/>

                        <!-- ─ COLONNA DESTRA ─ -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" MinHeight="180"/>
                                <RowDefinition Height="4"/>
                                <RowDefinition Height="220" MinHeight="120"/>
                            </Grid.RowDefinitions>

                            <!-- Step section -->
                            <Grid Grid.Row="0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EDF0F5" Padding="10,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Step del workflow selezionato"
                                                   Foreground="#1D4ED8" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                                        <Button Content="+ Aggiungi Step"  Style="{StaticResource BtnGreen}" Click="BtnWfAddStep_Click"/>
                                        <Button Content="✏️ Modifica Step"  Style="{StaticResource BtnBlue}"  Click="BtnWfEditStep_Click"/>
                                        <Button Content="↑"                 Style="{StaticResource BtnBlue}"  Click="BtnWfStepUp_Click"    Padding="10,6"/>
                                        <Button Content="↓"                 Style="{StaticResource BtnBlue}"  Click="BtnWfStepDown_Click"  Padding="10,6"/>
                                        <Button Content="🗑"                 Style="{StaticResource BtnRed}"   Click="BtnWfDeleteStep_Click" Padding="10,6"/>
                                    </StackPanel>
                                </Border>
                                <DataGrid x:Name="GridWfSteps" Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          SelectionMode="Single" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="#"        Binding="{Binding Ordine}"   Width="44"/>
                                        <DataGridTextColumn Header="Nome"     Binding="{Binding Nome}"     Width="*"/>
                                        <DataGridTextColumn Header="Tipo"     Binding="{Binding Tipo}"     Width="150"/>
                                        <DataGridTextColumn Header="Platform" Binding="{Binding Platform}" Width="80"/>
                                        <DataGridTextColumn Header="Parametri" Binding="{Binding Parametri}" Width="200"/>
                                        <DataGridTextColumn Header="Su errore" Binding="{Binding SuErrore}" Width="80"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>

                            <!-- Splitter orizzontale -->
                            <GridSplitter Grid.Row="1" Height="4"
                                          HorizontalAlignment="Stretch"
                                          Background="#D0D5DC"/>

                            <!-- Assegnazioni section -->
                            <Grid Grid.Row="2">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Grid.Row="0" Background="#EDF0F5" Padding="10,5">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="Assegnazioni (Deployment)"
                                                   Foreground="#1D4ED8" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" Margin="0,0,16,0" FontSize="12"/>
                                        <Button Content="+ Assegna a PC"   Style="{StaticResource BtnGreen}" Click="BtnWfAssign_Click"/>
                                        <Button Content="🔍 Dettaglio"      Style="{StaticResource BtnBlue}"  Click="BtnWfAssignDetail_Click"/>
                                        <Button Content="↻"                 Style="{StaticResource BtnBlue}"  Click="BtnWfRefreshAssign_Click" Padding="10,6"/>
                                        <Button Content="🗑"                 Style="{StaticResource BtnRed}"   Click="BtnWfDeleteAssign_Click"  Padding="10,6"/>
                                    </StackPanel>
                                </Border>
                                <DataGrid x:Name="GridWfAssignments" Grid.Row="1"
                                          AutoGenerateColumns="False"
                                          SelectionMode="Single" IsReadOnly="True"
                                          CanUserAddRows="False" CanUserDeleteRows="False">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="PC"       Binding="{Binding PcName}"       Width="130"/>
                                        <DataGridTextColumn Header="Workflow" Binding="{Binding WorkflowNome}" Width="*"/>
                                        <DataGridTextColumn Header="Stato"    Binding="{Binding Status}"       Width="80"/>
                                        <DataGridTemplateColumn Header="Progresso" Width="160">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Margin="4,2">
                                                        <ProgressBar Value="{Binding Progress}" Maximum="100"
                                                                     Height="7" Background="#E0E7F0"
                                                                     Foreground="{Binding ProgressColor}"/>
                                                        <TextBlock Text="{Binding ProgressText}"
                                                                   FontSize="10" Foreground="#64748b"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                        <DataGridTextColumn Header="Assegnato" Binding="{Binding AssignedAt}" Width="130"/>
                                        <DataGridTextColumn Header="Last seen" Binding="{Binding LastSeen}"   Width="130"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                            </Grid>
                        </Grid>
                    </Grid>

                    <!-- Status bar -->
                    <TextBlock x:Name="TxtWfStatus" Grid.Row="2"
                               Padding="10,4" Background="#EDF0F5"
                               Foreground="#475569" FontSize="11"
                               Text="Seleziona un workflow per vedere gli step"/>
                </Grid>
            </TabItem>

            <!-- ─── TAB RICHIESTE (CR) ─── -->
            <TabItem Header="📋  Richieste">
                <Grid Margin="0" Background="White">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="380"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- COLONNA SINISTRA: Form nuovo CR -->
                    <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto"
                                  Background="White" Padding="16,12,16,12"
                                  PreviewMouseWheel="SvPanel_PreviewMouseWheel">
                        <StackPanel>
                            <TextBlock Text="📋  Nuova Richiesta (CR)" FontSize="14" FontWeight="Bold"
                                       Foreground="#1D4ED8" Margin="0,0,0,12"/>

                            <!-- PC -->
                            <TextBlock Text="🖥️  Nome PC" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrPcName" Style="{StaticResource SettingsBox}"
                                     ToolTip="Es: PC-LAB-001 (maiuscolo automatico)"
                                     CharacterCasing="Upper"/>

                            <!-- Dominio -->
                            <TextBlock Text="🏢  Dominio" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrDomain" Style="{StaticResource SettingsBox}" Text="test.local"/>

                            <!-- OU -->
                            <TextBlock Text="📁  OU (Organizational Unit)" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrOu" Style="{StaticResource SettingsBox}"
                                     Text="CN=Computers,DC=test,DC=local"
                                     ToolTip="Es: OU=Lab,DC=test,DC=local"/>

                            <!-- IP DC -->
                            <TextBlock Text="🌐  IP Domain Controller" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrDcIp" Style="{StaticResource SettingsBox}" Text="192.168.10.185"/>

                            <!-- Join credentials -->
                            <TextBlock Text="👤  Utente join AD" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrJoinUser" Style="{StaticResource SettingsBox}" Text="join-account"/>

                            <TextBlock Text="🔑  Password join AD" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="TxtCrJoinPass" Style="{StaticResource SettingsPass}"/>

                            <!-- ODJ Blob (djoin.exe) -->
                            <Border Background="#D0D5DC" Height="1" Margin="0,4,0,8"/>
                            <TextBlock Text="— oppure: ODJ blob da djoin.exe (nessuna password nel XML) —"
                                       Foreground="#475569" FontSize="10"
                                       HorizontalAlignment="Center" Margin="0,0,0,6"/>
                            <TextBlock Text="🔑  ODJ Blob" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrOdjBlob" Style="{StaticResource SettingsBox}" Height="65"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     ToolTip="Incolla qui il base64 del file .djoin generato sul DC"
                                     FontFamily="Consolas" FontSize="10"/>
                            <Button Content="📋  Copia comando djoin"
                                    Style="{StaticResource BtnBlue}" FontSize="11"
                                    HorizontalAlignment="Left"
                                    Margin="0,0,0,12"
                                    Click="BtnCrCopyDjoin_Click"/>

                            <!-- Password admin -->
                            <TextBlock Text="🔑  Password Administrator" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <PasswordBox x:Name="TxtCrAdminPass" Style="{StaticResource SettingsPass}"/>

                            <!-- Utente assegnato -->
                            <TextBlock Text="👤  Utente assegnato (opzionale)" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrAssignedUser" Style="{StaticResource SettingsBox}"/>

                            <!-- Software -->
                            <TextBlock Text="📦  Software winget" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <Grid Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="36"/>
                                </Grid.ColumnDefinitions>
                                <TextBox x:Name="TxtCrNewPackage" Grid.Column="0"
                                         Style="{StaticResource SettingsBox}"
                                         ToolTip="Es: Mozilla.Firefox"
                                         KeyDown="TxtCrNewPackage_KeyDown"/>
                                <Button Content="➕" Grid.Column="1" Margin="4,0,0,0"
                                        Click="BtnCrAddPackage_Click"
                                        Style="{StaticResource BtnBlue}" Padding="0"/>
                            </Grid>
                            <ListBox x:Name="LstCrPackages" Height="90" Margin="0,0,0,10"
                                     Background="White" BorderBrush="#C8CDD5"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="24"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding}" Foreground="#222222" VerticalAlignment="Center"/>
                                            <Button Content="✕" Grid.Column="1" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#ff6b6b" FontSize="11"
                                                    Click="BtnCrRemovePackage_Click"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>

                            <!-- Note -->
                            <TextBlock Text="📝  Note" Foreground="#555555" FontSize="11" Margin="0,0,0,3"/>
                            <TextBox x:Name="TxtCrNotes" Style="{StaticResource SettingsBox}" Height="54"
                                     AcceptsReturn="True" TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"/>

                            <!-- Pulsanti -->
                            <Button x:Name="BtnCrCreate" Content="✅  Crea Richiesta"
                                    Style="{StaticResource BtnGreen}" Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    Click="BtnCrCreate_Click"/>
                            <Button x:Name="BtnCrRefresh" Content="🔄  Aggiorna lista"
                                    Style="{StaticResource BtnBlue}" Margin="0,0,0,6"
                                    HorizontalAlignment="Left"
                                    Click="BtnCrRefresh_Click"/>
                            <TextBlock x:Name="TxtCrStatus" Text="" Foreground="#1D4ED8"
                                       FontSize="11" TextWrapping="Wrap" Margin="0,6,0,0"/>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- COLONNA DESTRA: Lista CR -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="📋  Richieste attive"
                                   FontSize="13" FontWeight="Bold"
                                   Foreground="#1D4ED8" Margin="16,12,0,8"/>

                        <DataGrid x:Name="CrGrid" Grid.Row="1"
                                  AutoGenerateColumns="False" IsReadOnly="True"
                                  CanUserResizeRows="False" RowHeight="34"
                                  BorderThickness="1" GridLinesVisibility="Horizontal"
                                  FontSize="12"
                                  SelectionChanged="CrGrid_SelectionChanged">
                            <DataGrid.RowStyle>
                                <Style TargetType="DataGridRow">
                                    <Setter Property="Foreground" Value="#222222"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Status}" Value="completed">
                                            <Setter Property="Background" Value="#F0FDF4"/>
                                            <Setter Property="Foreground" Value="#15803D"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Status}" Value="in_progress">
                                            <Setter Property="Background" Value="#FFFBEB"/>
                                            <Setter Property="Foreground" Value="#B45309"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </DataGrid.RowStyle>
                            <DataGrid.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="✅  Segna Completato" Click="MenuCrComplete_Click"/>
                                    <MenuItem Header="🔄  Segna In lavorazione" Click="MenuCrInProgress_Click"/>
                                    <MenuItem Header="🗑  Elimina" Click="MenuCrDelete_Click"/>
                                    <Separator/>
                                    <MenuItem Header="💿  Genera file per USB" Click="MenuCrGenUsb_Click"/>
                                    <MenuItem Header="⬇️  Scarica autounattend.xml" Click="MenuCrDownloadXml_Click"/>
                                    <Separator/>
                                    <MenuItem Header="🔍  Task Sequence Debugger" Click="MenuCrDebug_Click"/>
                                </ContextMenu>
                            </DataGrid.ContextMenu>
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID"      Binding="{Binding Id}"           Width="45"/>
                                <DataGridTextColumn Header="Nome PC" Binding="{Binding PcName}"       Width="130"/>
                                <DataGridTextColumn Header="Dominio" Binding="{Binding Domain}"       Width="110"/>
                                <DataGridTextColumn Header="OU"      Binding="{Binding Ou}"           Width="180"/>
                                <DataGridTextColumn Header="Utente"  Binding="{Binding AssignedUser}" Width="110"/>
                                <DataGridTextColumn Header="Stato"   Binding="{Binding Status}"       Width="100"/>
                                <DataGridTextColumn Header="Creato"  Binding="{Binding CreatedAt}"    Width="140"/>
                                <DataGridTextColumn Header="Note"       Binding="{Binding Notes}"    Width="*"/>
                                <DataGridTextColumn Header="Check-in"  Binding="{Binding LastSeen}" Width="140"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── TAB SCCM ─── -->
            <TabItem Header="🖥️  SCCM">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra connessione -->
                    <Border Grid.Row="0" Background="#EDF0F5" BorderBrush="#C8D0DC"
                            BorderThickness="0,0,0,1" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Server:" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#555555"/>
                            <TextBox x:Name="TxtSccmServer" Width="180" Style="{StaticResource SettingsBox}" Text="192.168.10.199"/>
                            <TextBlock Text="Utente:" VerticalAlignment="Center" Margin="10,0,6,0" Foreground="#555555"/>
                            <TextBox x:Name="TxtSccmUser" Width="160" Style="{StaticResource SettingsBox}" Text="CORP\Administrator"/>
                            <TextBlock Text="Password:" VerticalAlignment="Center" Margin="10,0,6,0" Foreground="#555555"/>
                            <PasswordBox x:Name="TxtSccmPass" Width="130" Style="{StaticResource SettingsPass}"/>
                            <Button Content="🔌  Connetti" Style="{StaticResource BtnBlue}" Margin="10,0,0,0"
                                    Click="BtnSccmConnect_Click"/>
                            <Button x:Name="BtnSccmRefresh" Content="🔄  Aggiorna" Style="{StaticResource BtnBlue}"
                                    Margin="6,0,0,0" IsEnabled="False" Click="BtnSccmRefresh_Click"/>
                            <TextBlock x:Name="TxtSccmConnStatus" VerticalAlignment="Center"
                                       Margin="14,0,0,0" FontSize="11" Foreground="#555555"/>
                        </StackPanel>
                    </Border>

                    <!-- Contenuto principale -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="210"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Navigazione sinistra -->
                        <Border Grid.Column="0" Background="#F8F9FB"
                                BorderBrush="#D0D5DC" BorderThickness="0,0,1,0">
                            <TreeView x:Name="SccmNavTree" Background="Transparent"
                                      BorderThickness="0" Padding="4,8"
                                      SelectedItemChanged="SccmNavTree_SelectedItemChanged">
                                <TreeViewItem Header="🖥️  Dispositivi"     Tag="devices"      IsSelected="True"/>
                                <TreeViewItem Header="📋  Collezioni"      Tag="collections"/>
                                <TreeViewItem Header="🚀  Task Sequences"  Tag="tasksequences"/>
                                <TreeViewItem Header="📦  Applicazioni"    Tag="applications"/>
                                <TreeViewItem Header="📡  Deployments"     Tag="deployments"/>
                            </TreeView>
                        </Border>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="#D0D5DC" ShowsPreview="False"/>

                        <!-- Area destra -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar azioni -->
                            <Border Grid.Row="0" Background="#EDF0F5" Padding="8,6"
                                    BorderBrush="#D0D5DC" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock x:Name="TxtSccmSection" VerticalAlignment="Center"
                                               Foreground="#1D4ED8" FontWeight="SemiBold" FontSize="13"
                                               Margin="0,0,16,0" Text="Dispositivi"/>
                                    <Button x:Name="BtnSccmClientAction" Content="⚡  Azione client"
                                            Style="{StaticResource BtnBlue}" IsEnabled="False"
                                            Click="BtnSccmClientAction_Click"/>
                                    <Button x:Name="BtnSccmDeploy" Content="🚀  Deploy"
                                            Style="{StaticResource BtnGreen}" Margin="6,0,0,0"
                                            IsEnabled="False" Click="BtnSccmDeploy_Click"/>
                                    <Button x:Name="BtnSccmRunTs" Content="▶  Avvia TS"
                                            Style="{StaticResource BtnAmber}" Margin="6,0,0,0"
                                            IsEnabled="False" Click="BtnSccmRunTs_Click"/>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid risultati -->
                            <DataGrid x:Name="SccmGrid" Grid.Row="1"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      CanUserResizeRows="False" RowHeight="32"
                                      BorderThickness="0" GridLinesVisibility="Horizontal"
                                      FontSize="12" SelectionChanged="SccmGrid_SelectionChanged">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome"           Binding="{Binding Name}"        Width="200"/>
                                    <DataGridTextColumn Header="Tipo / Versione" Binding="{Binding Type}"       Width="140"/>
                                    <DataGridTextColumn Header="Stato"          Binding="{Binding Status}"      Width="100"/>
                                    <DataGridTextColumn Header="Ultimo contatto" Binding="{Binding LastContact}" Width="160"/>
                                    <DataGridTextColumn Header="Info"           Binding="{Binding Info}"        Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <!-- Barra stato -->
                            <Border Grid.Row="2" Background="#EDF0F5" BorderBrush="#D0D5DC"
                                    BorderThickness="0,1,0,0" Padding="8,4">
                                <TextBlock x:Name="TxtSccmStatus" FontSize="11" Foreground="#555555"
                                           Text="Non connesso — inserisci le credenziali e premi Connetti"/>
                            </Border>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── TAB SCRIPT LIBRARY ─── -->
            <TabItem Header="📜  Script">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="240"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Lista script sinistra -->
                    <Grid Grid.Column="0" Background="#0d1117">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Border Background="#1e3a5f" Padding="12,10">
                            <TextBlock Text="📜  Script Library" Foreground="#60a5fa"
                                       FontWeight="SemiBold" FontSize="12"/>
                        </Border>
                        <ListBox x:Name="ScriptList" Grid.Row="1"
                                 Background="Transparent" BorderThickness="0"
                                 SelectionChanged="ScriptList_SelectionChanged"
                                 Foreground="#c9d1d9" FontSize="12" Padding="0,4">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="12,7"/>
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter Property="Background" Value="#1e3a5f"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#0f2040"/>
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>
                        <StackPanel Grid.Row="2" Margin="8,8">
                            <Button Content="➕  Nuovo script" Style="{StaticResource BtnGreen}"
                                    Click="BtnNewScript_Click" Margin="0,0,0,4"/>
                            <Button Content="🗑  Elimina" Style="{StaticResource BtnRed}"
                                    Click="BtnDeleteScript_Click"/>
                        </StackPanel>
                    </Grid>

                    <!-- Editor + output destra -->
                    <Grid Grid.Column="1">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="190"/>
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <Border Grid.Row="0" Background="#161b22" Padding="14,9" BorderBrush="#30363d" BorderThickness="0,0,0,1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock x:Name="TxtScriptName" Text="Seleziona uno script dalla lista"
                                           Foreground="#60a5fa" FontSize="13" FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="TxtScriptDesc" Text=""
                                           Foreground="#64748b" FontSize="11"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Editor PowerShell -->
                        <TextBox x:Name="TxtScriptEditor" Grid.Row="1"
                                 Background="#0d1117" Foreground="#4ade80"
                                 FontFamily="Consolas" FontSize="13"
                                 BorderThickness="0" AcceptsReturn="True" AcceptsTab="True"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"
                                 TextWrapping="NoWrap" Padding="14,10"/>

                        <!-- Toolbar azioni -->
                        <Border Grid.Row="2" Background="#161b22" Padding="10,7" BorderBrush="#30363d" BorderThickness="0,1,0,1">
                            <StackPanel Orientation="Horizontal">
                                <Button Content="▶  Esegui su PC" Style="{StaticResource BtnGreen}"
                                        Click="BtnRunScriptOnPc_Click"
                                        ToolTip="Esegui su IP del PC selezionato in Rete (richiede WinRM attivo)"/>
                                <Button Content="🖥️  Localmente" Style="{StaticResource BtnBlue}"
                                        Click="BtnRunScriptLocal_Click"
                                        ToolTip="Esegui lo script su questo PC"/>
                                <Button Content="💾  Salva" Style="{StaticResource BtnAmber}"
                                        Click="BtnSaveScript_Click"/>
                                <Button Content="📤  .ps1" Style="{StaticResource BtnBlue}"
                                        Click="BtnExportScript_Click"
                                        ToolTip="Esporta come file .ps1"/>
                                <Border Width="1" Background="#334155" Margin="8,4"/>
                                <TextBlock Text="IP target:" Foreground="#64748b" FontSize="11"
                                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBox x:Name="TxtScriptTarget" Width="140"
                                         Style="{StaticResource SettingsBox}"
                                         Text="" ToolTip="IP del PC su cui eseguire (vuoto = PC selezionato in Rete)"/>
                                <TextBlock x:Name="TxtScriptRunStatus" Foreground="#94a3b8" FontSize="11"
                                           VerticalAlignment="Center" Margin="12,0,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Output -->
                        <Border Grid.Row="3" Background="#0a0f1e" BorderBrush="#1e3a5f" BorderThickness="0,0,0,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <StackPanel Orientation="Horizontal" Background="#0d1117" Margin="12,5">
                                    <TextBlock Text="📄  Output" Foreground="#64748b" FontSize="11"
                                               VerticalAlignment="Center"/>
                                    <Button Content="🗑 Pulisci" Margin="10,0,0,0" Padding="6,2"
                                            Background="Transparent" BorderBrush="#334155"
                                            Foreground="#64748b" FontSize="10" Cursor="Hand"
                                            Click="BtnClearScriptOutput_Click"/>
                                </StackPanel>
                                <TextBox x:Name="TxtScriptOutput" Grid.Row="1"
                                         Background="Transparent" Foreground="#a3e635"
                                         FontFamily="Consolas" FontSize="11"
                                         BorderThickness="0" IsReadOnly="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Padding="12,6"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── TAB WIKI ─── -->
            <TabItem Header="📖  Wiki">
                <Grid Margin="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Nav sinistra -->
                    <Border Grid.Column="0" Background="#0a0f1e" BorderBrush="#1e3a5f"
                            BorderThickness="0,0,1,0">
                        <StackPanel>
                            <TextBlock Text="📖  Documentazione" Foreground="#60a5fa"
                                       FontWeight="SemiBold" FontSize="11"
                                       Margin="12,14,12,10" TextWrapping="Wrap"/>
                            <ListBox x:Name="WikiNavList"
                                     Background="Transparent" BorderThickness="0"
                                     SelectionChanged="WikiNavList_SelectionChanged"
                                     Foreground="#94a3b8" FontSize="12">
                                <ListBoxItem Tag="overview"     Content="🏠  Panoramica"/>
                                <ListBoxItem Tag="scan"         Content="📡  Scansione Rete"/>
                                <ListBoxItem Tag="certs"        Content="🔐  Certificati EAP-TLS"/>
                                <ListBoxItem Tag="deploy"       Content="💿  Deploy Windows"/>
                                <ListBoxItem Tag="workflow"     Content="⚙️  Workflow"/>
                                <ListBoxItem Tag="pc"           Content="🖥️  Fleet PC"/>
                                <ListBoxItem Tag="opsi"         Content="📦  OPSI Software"/>
                                <ListBoxItem Tag="sccm"         Content="🏢  SCCM / OSD"/>
                                <ListBoxItem Tag="cr"           Content="📋  Change Requests"/>
                                <ListBoxItem Tag="faq"          Content="❓  FAQ"/>
                            </ListBox>
                        </StackPanel>
                    </Border>

                    <!-- Contenuto destra -->
                    <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto"
                                  PreviewMouseWheel="SvPanel_PreviewMouseWheel"
                                  Background="#F8FAFC">
                        <StackPanel x:Name="WikiContent" Margin="32,24,32,24"/>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ─── TAB PROXMOX ─── -->
            <TabItem Header="🖥️  Proxmox">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Barra connessione -->
                    <Border Grid.Row="0" Background="#1e293b" Padding="12,8">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Host:" Foreground="#94a3b8" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBox x:Name="TxtPveHost" Width="160" Padding="6,4"
                                     Background="#0f172a" Foreground="#e2e8f0" BorderBrush="#334155"
                                     FontFamily="Consolas" FontSize="12"
                                     Text="192.168.10.201"
                                     ToolTip="IP o hostname del nodo Proxmox"/>
                            <TextBlock Text="Utente:" Foreground="#94a3b8" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <TextBox x:Name="TxtPveUser" Width="120" Padding="6,4"
                                     Background="#0f172a" Foreground="#e2e8f0" BorderBrush="#334155"
                                     FontFamily="Consolas" FontSize="12" Text="root@pam"/>
                            <TextBlock Text="Password:" Foreground="#94a3b8" VerticalAlignment="Center" Margin="10,0,6,0"/>
                            <PasswordBox x:Name="TxtPvePass" Width="120" Padding="6,4"
                                         Background="#0f172a" Foreground="#e2e8f0" BorderBrush="#334155"
                                         FontSize="12"/>
                            <Button Content="🔌  Connetti" Style="{StaticResource BtnGreen}"
                                    Padding="12,5" Margin="12,0,0,0"
                                    Click="BtnPveConnect_Click"/>
                            <Button Content="🔄  Aggiorna" Style="{StaticResource BtnBlue}"
                                    x:Name="BtnPveRefresh" Padding="10,5" IsEnabled="False"
                                    Click="BtnPveRefresh_Click"/>
                            <TextBlock x:Name="TxtPveStatus" Foreground="#4ade80"
                                       VerticalAlignment="Center" Margin="16,0,0,0" FontSize="12"/>
                        </StackPanel>
                    </Border>

                    <!-- Contenuto: nodi + VM/CT -->
                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" MinWidth="160"/>
                            <ColumnDefinition Width="5"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                                      Background="#D0D5DC"/>

                        <!-- Pannello sinistro: nodi -->
                        <Border Grid.Column="0" Background="#f8fafc" BorderBrush="#e2e8f0" BorderThickness="0,0,1,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="  🖥️  Nodi" FontWeight="SemiBold"
                                           Background="#e2e8f0" Padding="8,6" FontSize="13"/>
                                <ListBox Grid.Row="1" x:Name="LstPveNodes"
                                         Background="Transparent" BorderThickness="0"
                                         SelectionChanged="LstPveNodes_SelectionChanged">
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Padding" Value="10,8"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding StatusIcon}" FontSize="14" Margin="0,0,6,0"/>
                                                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" FontSize="13"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding CpuText}" Foreground="#475569" FontSize="11" Margin="20,2,0,0"/>
                                                <TextBlock Text="{Binding RamText}" Foreground="#475569" FontSize="11" Margin="20,0,0,0"/>
                                                <TextBlock Text="{Binding GuestText}" Foreground="#1d4ed8" FontSize="11" Margin="20,0,0,2"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </Grid>
                        </Border>

                        <!-- Pannello destro: VM/CT -->
                        <Grid Grid.Column="2">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar azioni -->
                            <Border Grid.Row="0" Background="#f1f5f9" Padding="8,6"
                                    BorderBrush="#e2e8f0" BorderThickness="0,0,0,1">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="▶  Start"  Style="{StaticResource BtnGreen}"
                                            Padding="10,4" Click="BtnPveStart_Click"
                                            x:Name="BtnPveStart" IsEnabled="False"/>
                                    <Button Content="⏹  Stop"   Style="{StaticResource BtnRed}"
                                            Padding="10,4" Click="BtnPveStop_Click"
                                            x:Name="BtnPveStop" IsEnabled="False"/>
                                    <Button Content="🔄  Reboot" Style="{StaticResource BtnAmber}"
                                            Padding="10,4" Click="BtnPveReboot_Click"
                                            x:Name="BtnPveReboot" IsEnabled="False"/>
                                    <Button Content="⏸  Suspend" Style="{StaticResource BtnBlue}"
                                            Padding="10,4" Click="BtnPveSuspend_Click"
                                            x:Name="BtnPveSuspend" IsEnabled="False"/>
                                    <Separator Width="1" Background="#d1d5db" Margin="6,0"/>
                                    <Button Content="📟  Console" Style="{StaticResource BtnBlue}"
                                            Padding="10,4" Click="BtnPveConsole_Click"
                                            x:Name="BtnPveConsole" IsEnabled="False"
                                            ToolTip="Apri console VNC nel browser"/>
                                    <Separator Width="1" Background="#d1d5db" Margin="6,0"/>
                                    <TextBox x:Name="TxtPveFilter" Width="180" Padding="6,4"
                                             Background="White" BorderBrush="#d1d5db"
                                             FontSize="12" Tag="🔍  Filtra VM/CT..."
                                             ToolTip="Filtra per nome o VMID"
                                             TextChanged="TxtPveFilter_TextChanged"/>
                                </StackPanel>
                            </Border>

                            <!-- DataGrid VM/CT -->
                            <DataGrid Grid.Row="1" x:Name="DgPveGuests"
                                      AutoGenerateColumns="False"
                                      IsReadOnly="True"
                                      GridLinesVisibility="Horizontal"
                                      HeadersVisibility="Column"
                                      Background="White"
                                      RowBackground="White"
                                      AlternatingRowBackground="#f8fafc"
                                      BorderThickness="0"
                                      FontSize="12"
                                      SelectionMode="Single"
                                      SelectionChanged="DgPveGuests_SelectionChanged"
                                      CanUserSortColumns="True">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="VMID"   Binding="{Binding Vmid}"     Width="60"  CanUserSort="True"/>
                                    <DataGridTextColumn Header="Nome"   Binding="{Binding Name}"     Width="*"   CanUserSort="True"/>
                                    <DataGridTextColumn Header="Tipo"   Binding="{Binding TypeLabel}" Width="55"  CanUserSort="True"/>
                                    <DataGridTextColumn Header="Stato"  Binding="{Binding StatusLabel}" Width="80" CanUserSort="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <Trigger Property="Text" Value="▶ running">
                                                        <Setter Property="Foreground" Value="#16a34a"/>
                                                    </Trigger>
                                                    <Trigger Property="Text" Value="⏹ stopped">
                                                        <Setter Property="Foreground" Value="#dc2626"/>
                                                    </Trigger>
                                                    <Trigger Property="Text" Value="⏸ paused">
                                                        <Setter Property="Foreground" Value="#d97706"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="CPU %"  Binding="{Binding CpuLabel}"  Width="65"  CanUserSort="True"/>
                                    <DataGridTextColumn Header="RAM"    Binding="{Binding RamLabel}"   Width="90"  CanUserSort="True"/>
                                    <DataGridTextColumn Header="Disco"  Binding="{Binding DiskLabel}"  Width="90"  CanUserSort="True"/>
                                    <DataGridTextColumn Header="Uptime" Binding="{Binding UptimeLabel}" Width="90" CanUserSort="True"/>
                                    <DataGridTextColumn Header="Nodo"   Binding="{Binding Node}"       Width="80"  CanUserSort="True"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Grid>
                    </Grid>
                </Grid>
            </TabItem>

            <!-- ─── TAB ABOUT ─── -->
            <TabItem Header="ℹ️  About">
                <Grid>
                    <!-- Matrix rain canvas (sfondo) -->
                    <Canvas x:Name="MatrixCanvas" Background="#06080f" ClipToBounds="True"/>

                    <!-- Contenuto About (sopra il matrix) -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="Transparent"
                                  PreviewMouseWheel="SvPanel_PreviewMouseWheel">
                    <StackPanel Margin="40,24,40,24">

                        <!-- Titolo -->
                        <TextBlock Text="NovaSCM" FontSize="36" FontWeight="Bold" Foreground="#60a5fa"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Open Source Fleet &amp; Network Manager"
                                   FontSize="14" Foreground="#94a3b8" Margin="0,4,0,20"
                                   TextWrapping="Wrap"/>

                        <!-- Autore -->
                        <TextBlock Text="Developed by" Foreground="#64748b" FontSize="12" TextWrapping="Wrap"/>
                        <TextBlock Text="Claudio Becchis" FontSize="22" FontWeight="SemiBold"
                                   Foreground="#e2e8f0" Margin="0,2,0,6" TextWrapping="Wrap"/>
                        <TextBlock Text="Powered by" Foreground="#64748b" FontSize="12" Margin="0,6,0,0" TextWrapping="Wrap"/>
                        <TextBlock Text="PolarisCore.it" FontSize="16" FontWeight="SemiBold"
                                   Foreground="#60a5fa" Margin="0,2,0,20" TextWrapping="Wrap"/>

                        <!-- Funzionalità -->
                        <TextBlock Text="📋  Funzionalità" Foreground="#60a5fa"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border Background="#0d1b3e90" BorderBrush="#1e3a5f" BorderThickness="1"
                                CornerRadius="6" Padding="16,12" Margin="0,0,0,16">
                            <TextBlock Foreground="#94a3b8" FontSize="12" LineHeight="22"
                                       TextWrapping="Wrap">
                                <TextBlock.Text>•  Scansione rete — IP, MAC, Vendor, Tipo device
•  Scansione porte aperte per ogni device
•  Connessione RDP e SSH one-click
•  Gestione certificati WiFi EAP-TLS
•  Registrazione device via MAC
•  Deploy Windows unattended con autounattend.xml
•  Task Sequence Debugger (stile SCCM)
•  Completamente configurabile da GUI</TextBlock.Text>
                            </TextBlock>
                        </Border>

                        <!-- Licenza -->
                        <TextBlock Text="📄  Licenza" Foreground="#60a5fa"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border Background="#0d1b3e90" BorderBrush="#1e3a5f" BorderThickness="1"
                                CornerRadius="6" Padding="16,12" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Foreground="#94a3b8" FontSize="12" LineHeight="22"
                                           TextWrapping="Wrap">
                                    <TextBlock.Text>MIT License — Software libero e open source
Puoi usare, modificare e distribuire liberamente mantenendo il credito all'autore originale.</TextBlock.Text>
                                </TextBlock>
                                <TextBlock Margin="0,10,0,0" Foreground="#64748b" FontSize="11"
                                           TextWrapping="Wrap"
                                           Text="© 2026 Claudio Becchis — PolarisCore.it"/>
                            </StackPanel>
                        </Border>

                        <!-- Supporta il progetto -->
                        <TextBlock Text="☕  Supporta il progetto" Foreground="#f59e0b"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                        <Border Background="#0d1b3e90" BorderBrush="#f59e0b40" BorderThickness="1"
                                CornerRadius="6" Padding="16,14" Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Foreground="#fbbf24" FontSize="14" FontWeight="SemiBold"
                                           TextWrapping="Wrap" Margin="0,0,0,6"
                                           Text="NovaSCM è e resterà sempre gratuito."/>
                                <TextBlock Foreground="#94a3b8" FontSize="12" LineHeight="20"
                                           TextWrapping="Wrap"
                                           Text="Ho sviluppato questo strumento nel tempo libero per automatizzare la gestione della mia rete di casa — e ho deciso di condividerlo con tutti.&#10;Se ti fa risparmiare tempo, se ti ha risolto un problema o semplicemente ti piace il progetto, considera di offrirmi un caffè: mi aiuta a continuare a migliorarlo!"/>
                                <TextBlock Foreground="#64748b" FontSize="11" Margin="0,8,0,0"
                                           TextWrapping="Wrap"
                                           Text="Anche 1€ fa la differenza. Grazie davvero. 🙏"/>
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                                    <Button Content="☕  Offrimi un caffè — Ko-fi" Padding="14,8" Margin="0,0,10,0"
                                            Background="#FF5E5B" BorderBrush="#E04040" Foreground="White"
                                            FontWeight="SemiBold" Cursor="Hand"
                                            Click="BtnKofi_Click"/>
                                    <Button Content="💛  Sponsor su GitHub" Padding="14,8" Margin="0,0,10,0"
                                            Background="#db61a2" BorderBrush="#c0498e" Foreground="White"
                                            FontWeight="SemiBold" Cursor="Hand"
                                            Click="BtnGitHubSponsor_Click"/>
                                    <Button Content="🅿  PayPal" Padding="14,8"
                                            Background="#003087" BorderBrush="#0070ba" Foreground="White"
                                            FontWeight="SemiBold" Cursor="Hand"
                                            Click="BtnPayPal_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Pulsanti -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="🌐  PolarisCore.it" Padding="14,7" Margin="0,0,10,0"
                                    Style="{StaticResource BtnBlue}"
                                    Click="BtnOpenWebsite_Click"/>
                            <Button Content="📁  GitHub" Padding="14,7" Margin="0,0,10,0"
                                    Style="{StaticResource BtnBlue}"
                                    Click="BtnOpenGitHub_Click"/>
                            <Button Content="🔄  Controlla aggiornamenti" Padding="14,7"
                                    Style="{StaticResource BtnGreen}"
                                    Click="BtnCheckUpdate_Click"/>
                        </StackPanel>

                        <!-- Demo stili GUI -->
                        <TextBlock Text="🎨  Demo Stili GUI" Foreground="#60a5fa"
                                   FontWeight="SemiBold" FontSize="13" Margin="0,16,0,8" TextWrapping="Wrap"/>
                        <TextBlock Text="Confronta i tre stili visivi per scegliere il design finale di NovaSCM."
                                   Foreground="#94a3b8" FontSize="12" Margin="0,0,0,10" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Button Content="🏢  SCCM Console Style" Padding="14,8" Margin="0,0,10,0"
                                    Background="#1F3864" BorderBrush="#2B579A" Foreground="White"
                                    Click="BtnDemoSCCM_Click"/>
                            <Button Content="🔵  Advanced Installer Style" Padding="14,8" Margin="0,0,10,0"
                                    Background="#073682" BorderBrush="#0A78C9" Foreground="White"
                                    Click="BtnDemoAI_Click"/>
                            <Button Content="📦  MSIX Packaging Tool Style" Padding="14,8" Margin="0,0,10,0"
                                    Background="#0078D4" BorderBrush="#005A9E" Foreground="White"
                                    Click="BtnDemoMSIX_Click"/>
                            <Button Content="✨  Ibrido (SCCM + Advanced Installer)" Padding="14,8"
                                    Background="#073682" BorderBrush="#0A78C9" Foreground="#A8D0F0"
                                    Click="BtnDemoHybrid_Click"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtUpdateStatus" FontSize="12" Margin="0,0,0,16"
                                   TextWrapping="Wrap" Foreground="#475569"/>

                        <!-- Versione -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtAboutVersion" Foreground="#94a3b8" FontSize="12"
                                       VerticalAlignment="Center"/>
                            <Border Background="#052e16" CornerRadius="4" Padding="8,3">
                                <TextBlock Text="STABLE" Foreground="#4ade80"
                                           FontSize="10" FontWeight="Bold"/>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                    </ScrollViewer>
                </Grid>
            </TabItem>

            <!-- ─── TAB IMPOSTAZIONI ─── -->
            <TabItem Header="⚙️  Impostazioni">
                <ScrollViewer Margin="20,12,20,12" VerticalScrollBarVisibility="Auto"
                              PreviewMouseWheel="SvPanel_PreviewMouseWheel">
                    <StackPanel MaxWidth="560" HorizontalAlignment="Left">

                        <TextBlock Text="⚙️  Configurazione server" Style="{StaticResource SectionLabel}"/>

                        <!-- Sezione Server -->
                        <TextBlock Text="🌐 Server" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="Certportal URL" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtCertportalUrl" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: https://certportal.miarete.it oppure http://192.168.1.110:9090"/>

                        <TextBlock Text="UniFi Controller URL" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtUnifiUrl" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: https://192.168.1.1"/>

                        <TextBlock Text="UniFi Username" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtUnifiUser" Style="{StaticResource SettingsBox}"/>

                        <TextBlock Text="UniFi Password" Style="{StaticResource SettingsLabel}"/>
                        <PasswordBox x:Name="TxtUnifiPass" Style="{StaticResource SettingsPass}"/>

                        <!-- Sezione WiFi / RADIUS -->
                        <TextBlock Text="📡 WiFi / RADIUS" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="SSID rete sicura (EAP-TLS)" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtSsid" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: MiaRete-Secure"/>

                        <TextBlock Text="RADIUS Server IP" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtRadiusIp" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: 192.168.1.105"/>

                        <!-- Sezione Certificati -->
                        <TextBlock Text="🔐 Certificati" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="Validità certificati (giorni)" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtCertDays" Style="{StaticResource SettingsBox}" Text="3650"
                                 ToolTip="Default: 3650 (10 anni)"/>

                        <!-- Sezione subnet multiple -->
                        <TextBlock Text="🌐 Subnet da scansionare" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="Reti (una per riga, formato 192.168.x.0/24)"
                                   Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtScanNetworks"
                                 Background="White" Foreground="#1a1a1a"
                                 BorderBrush="#C8CDD5" Padding="8,4" FontSize="13"
                                 Width="320" HorizontalAlignment="Left"
                                 AcceptsReturn="True" TextWrapping="Wrap" Height="110"
                                 VerticalScrollBarVisibility="Auto"
                                 ToolTip="Usato dal pulsante 'Tutte le VLAN' nel tab Rete"/>

                        <!-- Sezione WinRM / Inventario -->
                        <TextBlock Text="🖥️ Inventario / WinRM" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="Username admin remoto" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtAdminUser" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: Administrator — usato per WMI remoto e inventario hardware/software"/>

                        <TextBlock Text="Password admin remoto" Style="{StaticResource SettingsLabel}"/>
                        <PasswordBox x:Name="TxtAdminPass" Style="{StaticResource SettingsPass}"/>

                        <TextBlock Foreground="#475569" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"
                                   Text="⚠️  Abilita WinRM sui PC target con:  Enable-PSRemoting -Force  (da PowerShell admin)"/>

                        <!-- Sezione Organizzazione -->
                        <TextBlock Text="🏢 Organizzazione" Style="{StaticResource GroupTitle}"/>

                        <TextBlock Text="Nome organizzazione" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtOrgName" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: PolarisCore / MiaAzienda Srl"/>

                        <TextBlock Text="Dominio" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtDomain" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: polariscore.it / miazienda.local"/>

                        <!-- Sezione NovaSCM API -->
                        <TextBlock Text="🔧 NovaSCM / CR" Style="{StaticResource GroupTitle}"/>
                        <TextBlock Text="URL API NovaSCM (tab Richieste)" Style="{StaticResource SettingsLabel}"/>
                        <TextBox x:Name="TxtNovaSCMApiUrl" Style="{StaticResource SettingsBox}"
                                 ToolTip="Es: http://192.168.20.110:9091/api/cr"/>

                        <!-- Pulsanti -->
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="💾  Salva impostazioni" Style="{StaticResource BtnGreen}"
                                    Click="BtnSaveSettings_Click"/>
                            <Button Content="🔍  Test connessione" Style="{StaticResource BtnBlue}"
                                    Click="BtnTestConnection_Click"/>
                        </StackPanel>

                        <TextBlock x:Name="TxtSettingsStatus" Foreground="#10b981"
                                   FontSize="12" Margin="0,10,0,0" Text=""/>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>

    </DockPanel>

    <!-- ═══ KONAMI CODE OVERLAY ═══ -->
    <Grid x:Name="KonamiOverlay" Visibility="Collapsed" Panel.ZIndex="9999"
          Background="#E0000000">
        <Canvas x:Name="KonamiCanvas" ClipToBounds="True"/>
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="TxtKonamiGlitch"
                       Text="↑↑↓↓←→←→BA"
                       FontFamily="Consolas" FontSize="13" Foreground="#1a5c1a"
                       HorizontalAlignment="Center" Margin="0,0,0,12" Opacity="0.7"/>
            <Border Background="#041a04" BorderBrush="#00ff41" BorderThickness="2"
                    CornerRadius="4" Padding="40,20">
                <StackPanel>
                    <TextBlock Text="🔓  CHEAT CODE ATTIVATO"
                               FontFamily="Consolas" FontSize="28" FontWeight="Bold"
                               Foreground="#00ff41" HorizontalAlignment="Center">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#00ff41" BlurRadius="20" ShadowDepth="0" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock x:Name="TxtKonamiSub" Margin="0,10,0,0"
                               FontFamily="Consolas" FontSize="14"
                               Foreground="#4ade80" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>

    </Grid>
</Window>
