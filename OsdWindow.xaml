<!-- NovaSCM v1.4.0 -->
<Window x:Class="PolarisManager.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized"
        AllowsTransparency="False" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Background="#001640" FontFamily="Segoe UI"
        KeyDown="Window_KeyDown">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="72"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="52"/>
        </Grid.RowDefinitions>

        <!-- ── HEADER ── -->
        <Border Grid.Row="0" Background="#000c28">
            <Grid Margin="36,0">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="#1d4ed8" CornerRadius="6" Width="38" Height="38"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                        <TextBlock Text="N" FontSize="22" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="NovaSCM" FontSize="20" FontWeight="SemiBold" Foreground="White"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" — Configurazione automatica" FontSize="14"
                               Foreground="#4a7cbf" VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock x:Name="TxtOsdPcName" HorizontalAlignment="Right"
                           FontSize="14" Foreground="#4a7cbf" VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- ── CONTENT ── -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="360"/>
            </Grid.ColumnDefinitions>

            <!-- Sinistra: stato corrente -->
            <Grid Grid.Column="0">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                            Width="460">
                    <!-- Icona animata -->
                    <TextBlock x:Name="TxtOsdIcon" Text="⚙" FontSize="64"
                               Foreground="#3b82f6" HorizontalAlignment="Center"
                               Margin="0,0,0,24">
                        <TextBlock.RenderTransform>
                            <RotateTransform x:Name="IconRotate" CenterX="32" CenterY="32"/>
                        </TextBlock.RenderTransform>
                        <TextBlock.Triggers>
                            <EventTrigger RoutedEvent="Loaded">
                                <BeginStoryboard>
                                    <Storyboard RepeatBehavior="Forever">
                                        <DoubleAnimation
                                            Storyboard.TargetName="IconRotate"
                                            Storyboard.TargetProperty="Angle"
                                            From="0" To="360" Duration="0:0:4"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </TextBlock.Triggers>
                    </TextBlock>

                    <!-- Step corrente -->
                    <TextBlock x:Name="TxtOsdCurrentStep"
                               Text="Avvio in corso..." FontSize="22"
                               FontWeight="SemiBold" Foreground="White"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,8"/>
                    <TextBlock x:Name="TxtOsdSubStep"
                               Text="" FontSize="13" Foreground="#4a7cbf"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               Margin="0,0,0,32"/>

                    <!-- Barra progresso -->
                    <ProgressBar x:Name="OsdProgress" Height="10" Width="420"
                                 Minimum="0" Maximum="100" Value="0"
                                 Margin="0,0,0,8">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Foreground" Value="#3b82f6"/>
                                <Setter Property="Background" Value="#0a2a5a"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ProgressBar">
                                            <Border CornerRadius="5" Background="{TemplateBinding Background}">
                                                <Border x:Name="PART_Indicator"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="5"
                                                        Background="{TemplateBinding Foreground}"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>
                    <TextBlock x:Name="TxtOsdPercent" Text="0%" FontSize="12"
                               Foreground="#4a7cbf" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <!-- Destra: step list -->
            <Border Grid.Column="1" Background="#000c28"
                    Margin="0,24,24,24" CornerRadius="10">
                <Grid Margin="20,20,20,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Passi di configurazione"
                               FontSize="12" FontWeight="SemiBold"
                               Foreground="#4a7cbf" Margin="0,0,0,14"/>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                        <ItemsControl x:Name="OsdStepList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="26"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Icon}" FontSize="15"
                                                   Foreground="{Binding IconColor}"
                                                   VerticalAlignment="Top"/>
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Label}" FontSize="13"
                                                       Foreground="{Binding TextColor}"
                                                       FontWeight="{Binding Weight}"/>
                                            <TextBlock Text="{Binding Sub}" FontSize="11"
                                                       Foreground="#374151"
                                                       Visibility="{Binding SubVisible}"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- ── FOOTER ── -->
        <Border Grid.Row="2" Background="#000c28">
            <Grid Margin="36,0">
                <TextBlock Text="Non spegnere il computer durante la configurazione automatica."
                           Foreground="#374151" FontSize="12" VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtOsdElapsed"
                           HorizontalAlignment="Right"
                           Foreground="#374151" FontSize="12" VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</Window>
