<!-- NovaSCM v1.8.2 -->
<Window x:Class="PolarisManager.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None" WindowState="Maximized"
        AllowsTransparency="False" Topmost="True"
        ShowInTaskbar="False" ResizeMode="NoResize"
        Background="#05080f" FontFamily="Segoe UI"
        Foreground="#C3D2EB"
        KeyDown="Window_KeyDown">
    <Grid>
        <!-- BG: grid lines sottili -->
        <Grid.Background>
            <DrawingBrush TileMode="Tile" Viewport="0,0,56,56" ViewportUnits="Absolute">
                <DrawingBrush.Drawing>
                    <DrawingGroup>
                        <GeometryDrawing Brush="#05080f">
                            <GeometryDrawing.Geometry><RectangleGeometry Rect="0,0,56,56"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen><Pen Brush="#090E1C" Thickness="1"/></GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry><LineGeometry StartPoint="0,55" EndPoint="56,55"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                        <GeometryDrawing>
                            <GeometryDrawing.Pen><Pen Brush="#090E1C" Thickness="1"/></GeometryDrawing.Pen>
                            <GeometryDrawing.Geometry><LineGeometry StartPoint="55,0" EndPoint="55,56"/></GeometryDrawing.Geometry>
                        </GeometryDrawing>
                    </DrawingGroup>
                </DrawingBrush.Drawing>
            </DrawingBrush>
        </Grid.Background>

        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>   <!-- 0: Header -->
            <RowDefinition Height="42"/>   <!-- 1: HW Strip -->
            <RowDefinition Height="1"/>    <!-- 2: Divider -->
            <RowDefinition Height="*"/>    <!-- 3: Content -->
            <RowDefinition Height="1"/>    <!-- 4: Divider -->
            <RowDefinition Height="38"/>   <!-- 5: Footer -->
        </Grid.RowDefinitions>

        <!-- ══ HEADER ══ -->
        <Grid Grid.Row="0" Margin="52,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Grid.Column="0">
                <Border Width="40" Height="40" CornerRadius="9"
                        Background="#0D1929" BorderThickness="1.5"
                        BorderBrush="#1F3A60" Margin="0,0,12,0">
                    <TextBlock Text="N" FontFamily="Consolas" FontSize="17" FontWeight="Medium"
                               Foreground="#4D9FFF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="NOVASCM" FontFamily="Consolas" FontSize="13" FontWeight="Medium"
                               Foreground="#E8F0FF"/>
                    <TextBlock Text="DEPLOYMENT AGENT" FontFamily="Consolas" FontSize="8"
                               Foreground="#3C5078" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="TxtOsdPcName" Text="—"
                           FontFamily="Consolas" FontSize="28" FontWeight="Medium"
                           Foreground="#E8F0FF" HorizontalAlignment="Center"/>
                <TextBlock x:Name="TxtOsdDomain" Text=""
                           FontFamily="Consolas" FontSize="10" Foreground="#3C5078"
                           HorizontalAlignment="Center" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right">
                <Border CornerRadius="4" Padding="10,4" BorderThickness="1"
                        BorderBrush="#1A3356" Margin="0,0,0,5">
                    <Border.Background>
                        <SolidColorBrush Color="#4D9FFF" Opacity="0.07"/>
                    </Border.Background>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="LedDot" Width="6" Height="6" Fill="#4D9FFF" Margin="0,0,7,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="TxtOsdWfName" Text="Deployment"
                                   FontFamily="Consolas" FontSize="9" Foreground="#4D9FFF"/>
                    </StackPanel>
                </Border>
                <TextBlock x:Name="TxtOsdClock" Text="—"
                           FontFamily="Consolas" FontSize="10" Foreground="#3C5078"
                           HorizontalAlignment="Right"/>
            </StackPanel>
        </Grid>

        <!-- ══ HW STRIP ══ -->
        <Grid Grid.Row="1" Margin="52,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="1.5*"/>
            </Grid.ColumnDefinitions>

            <!-- CPU -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,16,0">
                <TextBlock Text="🖥" FontSize="14" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHwCpu" Text="rilevamento…"
                               FontFamily="Consolas" FontSize="11" FontWeight="Medium" Foreground="#E8F0FF"/>
                    <TextBlock Text="MODELLO CPU" FontFamily="Consolas" FontSize="8"
                               Foreground="#283C5A" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="1" Background="#1E2A45"/>

            <!-- RAM -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="💾" FontSize="14" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHwRam" Text="rilevamento…"
                               FontFamily="Consolas" FontSize="11" FontWeight="Medium" Foreground="#E8F0FF"/>
                    <TextBlock Text="RAM" FontFamily="Consolas" FontSize="8"
                               Foreground="#283C5A" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="3" Background="#1E2A45"/>

            <!-- Disco -->
            <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                <TextBlock Text="💿" FontSize="14" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHwDisk" Text="rilevamento…"
                               FontFamily="Consolas" FontSize="11" FontWeight="Medium" Foreground="#E8F0FF"/>
                    <TextBlock Text="DISCO" FontFamily="Consolas" FontSize="8"
                               Foreground="#283C5A" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
            <Border Grid.Column="5" Background="#1E2A45"/>

            <!-- Rete -->
            <StackPanel Grid.Column="6" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                <TextBlock Text="🌐" FontSize="14" Opacity="0.5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock x:Name="TxtHwMac" Text="rilevamento…"
                               FontFamily="Consolas" FontSize="11" FontWeight="Medium" Foreground="#E8F0FF"/>
                    <TextBlock x:Name="TxtHwIp" Text="—"
                               FontFamily="Consolas" FontSize="10" Foreground="#829696" Margin="0,1,0,0"/>
                    <TextBlock Text="RETE — MAC / IP" FontFamily="Consolas" FontSize="8"
                               Foreground="#283C5A" Margin="0,1,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Divider top -->
        <Border Grid.Row="2" Background="#1E2A45"/>

        <!-- ══ CONTENT ══ -->
        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="1"/>
                <ColumnDefinition Width="340"/>
            </Grid.ColumnDefinitions>

            <!-- ── COLONNA SINISTRA ── -->
            <Grid Grid.Column="0" Margin="52,22,48,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Ring + step name -->
                    <RowDefinition Height="16"/>
                    <RowDefinition Height="Auto"/>  <!-- Progress bar -->
                    <RowDefinition Height="14"/>
                    <RowDefinition Height="Auto"/>  <!-- Stats -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>  <!-- Cur-box -->
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>     <!-- Log box -->
                </Grid.RowDefinitions>

                <!-- Ring + step corrente -->
                <StackPanel Grid.Row="0" Orientation="Horizontal">
                    <Grid Width="90" Height="90" Margin="0,0,22,0">
                        <Canvas Width="90" Height="90">
                            <Path Data="M 45,5 A 40,40 0 1,1 44.9999,5.0001"
                                  Stroke="#141E35" StrokeThickness="5" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                            <Path x:Name="RingArcPath"
                                  Stroke="#4D9FFF" StrokeThickness="5" Fill="Transparent"
                                  StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                        </Canvas>
                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                            <TextBlock x:Name="TxtRingPct" Text="0%"
                                       FontFamily="Consolas" FontSize="20" FontWeight="Medium"
                                       Foreground="#E8F0FF" TextAlignment="Center"/>
                            <TextBlock Text="FATTO" FontFamily="Consolas" FontSize="7"
                                       Foreground="#3C5078" TextAlignment="Center"/>
                        </StackPanel>
                    </Grid>
                    <StackPanel VerticalAlignment="Center" MaxWidth="380">
                        <TextBlock x:Name="TxtCurStepName" Text="Avvio in corso…"
                                   FontSize="21" FontWeight="Light" Foreground="#E8F0FF"
                                   TextWrapping="Wrap"/>
                        <TextBlock x:Name="TxtCurStepTipo" Text="inizializzazione"
                                   FontFamily="Consolas" FontSize="10" Foreground="#4D9FFF"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </StackPanel>

                <!-- Barra progresso -->
                <Grid Grid.Row="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="6"/>
                    </Grid.RowDefinitions>
                    <Grid>
                        <TextBlock Text="Progresso" FontFamily="Consolas" FontSize="9" Foreground="#3C5078"/>
                        <TextBlock x:Name="TxtBarSteps" Text="step 0 / 0"
                                   FontFamily="Consolas" FontSize="9" Foreground="#3C5078"
                                   HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar x:Name="OsdProgress" Grid.Row="1" Height="4"
                                 Minimum="0" Maximum="100" Value="0">
                        <ProgressBar.Template>
                            <ControlTemplate TargetType="ProgressBar">
                                <Border CornerRadius="2" Background="#0D1929">
                                    <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="2">
                                        <Border.Background>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Color="#2A6FFF" Offset="0"/>
                                                <GradientStop Color="#7EC8FF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Border.Background>
                                    </Border>
                                </Border>
                            </ControlTemplate>
                        </ProgressBar.Template>
                    </ProgressBar>
                </Grid>

                <!-- Statistiche: 4 celle -->
                <Grid Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,8,14,8">
                        <TextBlock x:Name="TxtStatDone" Text="0"
                                   FontFamily="Consolas" FontSize="22" FontWeight="Medium" Foreground="#4D9FFF"/>
                        <TextBlock Text="COMPLETATI" FontFamily="Consolas" FontSize="8"
                                   Foreground="#3C5078" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="0" Width="1" HorizontalAlignment="Right" Background="#1E2A45" Margin="0,6,0,6"/>
                    <StackPanel Grid.Column="1" Margin="14,8">
                        <TextBlock x:Name="TxtStatRem" Text="0"
                                   FontFamily="Consolas" FontSize="22" FontWeight="Medium" Foreground="#C3D2EB"/>
                        <TextBlock Text="RIMANENTI" FontFamily="Consolas" FontSize="8"
                                   Foreground="#3C5078" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="1" Width="1" HorizontalAlignment="Right" Background="#1E2A45" Margin="0,6,0,6"/>
                    <StackPanel Grid.Column="2" Margin="14,8">
                        <TextBlock x:Name="TxtStatEta" Text="—"
                                   FontFamily="Consolas" FontSize="22" FontWeight="Medium" Foreground="#F5A623"/>
                        <TextBlock Text="STIMA FIN." FontFamily="Consolas" FontSize="8"
                                   Foreground="#3C5078" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Border Grid.Column="2" Width="1" HorizontalAlignment="Right" Background="#1E2A45" Margin="0,6,0,6"/>
                    <StackPanel Grid.Column="3" Margin="14,8,0,8">
                        <TextBlock x:Name="TxtStatEla" Text="—"
                                   FontFamily="Consolas" FontSize="22" FontWeight="Medium" Foreground="#C3D2EB"/>
                        <TextBlock Text="TRASCORSO" FontFamily="Consolas" FontSize="8"
                                   Foreground="#3C5078" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>

                <!-- Cur-box -->
                <Border Grid.Row="6" Padding="14,10" CornerRadius="7"
                        BorderThickness="1" BorderBrush="#1A3356">
                    <Border.Background>
                        <SolidColorBrush Color="#4D9FFF" Opacity="0.04"/>
                    </Border.Background>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="36"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border x:Name="CurSpinnerBorder" Grid.Column="0"
                                Width="28" Height="28" CornerRadius="14"
                                BorderThickness="2" BorderBrush="#1F3A60"
                                VerticalAlignment="Center">
                            <TextBlock x:Name="CurSpinnerIcon" Text="▶"
                                       FontSize="10" Foreground="#4D9FFF"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel Grid.Column="1" Margin="14,0,0,0" VerticalAlignment="Center">
                            <TextBlock x:Name="TxtCurBoxName" Text="In attesa dell'agente…"
                                       FontSize="13" FontWeight="Medium" Foreground="#E8F0FF"
                                       TextTrimming="CharacterEllipsis"/>
                            <TextBlock x:Name="TxtCurBoxTipo" Text="—"
                                       FontFamily="Consolas" FontSize="9" Foreground="#3C5078"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtCurBoxTime" Grid.Column="2" Text="—"
                                   FontFamily="Consolas" FontSize="13" Foreground="#4D9FFF"
                                   VerticalAlignment="Center" Margin="10,0,0,0"/>
                    </Grid>
                </Border>

                <!-- Log box -->
                <Grid Grid.Row="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Margin="0,0,0,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="5" Height="5" Fill="#4D9FFF"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="OUTPUT — " FontFamily="Consolas" FontSize="9"
                                       Foreground="#3C5078" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtLogStepName" Text="—"
                                       FontFamily="Consolas" FontSize="9" Foreground="#3C5078"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock x:Name="TxtLogLines" Text="0 righe"
                                   FontFamily="Consolas" FontSize="8" Foreground="#1E2A45"
                                   HorizontalAlignment="Right" VerticalAlignment="Center"/>
                    </Grid>
                    <ScrollViewer x:Name="LogScrollViewer" Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MinHeight="72">
                        <ScrollViewer.Resources>
                            <Style TargetType="ScrollBar">
                                <Setter Property="Width" Value="3"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ScrollViewer.Resources>
                        <Border Background="#030609" BorderThickness="1"
                                BorderBrush="#12192E" CornerRadius="5" Padding="8,6">
                            <ItemsControl x:Name="LogLines">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}"
                                                   FontFamily="Consolas" FontSize="9.5"
                                                   TextWrapping="Wrap"
                                                   Foreground="{Binding ForeColor}"
                                                   Margin="0,0,0,1"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </ScrollViewer>
                </Grid>
            </Grid>

            <!-- Divider verticale -->
            <Border Grid.Column="1" Background="#1E2A45"/>

            <!-- ── COLONNA DESTRA: pipeline ── -->
            <Grid Grid.Column="2" Margin="22,18,26,14">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <TextBlock Text="PIPELINE"
                               FontFamily="Consolas" FontSize="9" Foreground="#3C5078"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="TxtStepsCount" Text="— step"
                               FontFamily="Consolas" FontSize="9" Foreground="#3C5078"
                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                </Grid>

                <ScrollViewer Grid.Row="2" x:Name="StepScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <ScrollViewer.Resources>
                        <Style TargetType="ScrollBar">
                            <Setter Property="Width" Value="3"/>
                            <Setter Property="Background" Value="Transparent"/>
                        </Style>
                    </ScrollViewer.Resources>
                    <ItemsControl x:Name="OsdStepList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid MinHeight="36">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="26"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Cerchio + connettore -->
                                    <Grid Grid.Column="0" VerticalAlignment="Stretch">
                                        <Border Width="2" HorizontalAlignment="Center"
                                                VerticalAlignment="Stretch" Margin="0,25,0,0"
                                                Visibility="{Binding ConnectorVisible}"
                                                Background="#1E2A45"/>
                                        <Border x:Name="StepCircle"
                                                Width="18" Height="18" CornerRadius="9"
                                                HorizontalAlignment="Center" VerticalAlignment="Top"
                                                Margin="0,7,0,0" BorderThickness="1.5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#0A1020"/>
                                                    <Setter Property="BorderBrush" Value="#1E2A45"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="done">
                                                            <Setter Property="Background" Value="#071A10"/>
                                                            <Setter Property="BorderBrush" Value="#00D97E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="running">
                                                            <Setter Property="Background" Value="#0D1E35"/>
                                                            <Setter Property="BorderBrush" Value="#4D9FFF"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="error">
                                                            <Setter Property="Background" Value="#1A0A10"/>
                                                            <Setter Property="BorderBrush" Value="#FF4757"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding CircleIcon}"
                                                       FontFamily="Consolas" FontSize="8"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{Binding CircleIconColor}"/>
                                        </Border>
                                    </Grid>

                                    <!-- Body step -->
                                    <Border Grid.Column="1" Margin="3,2,0,2" Padding="7,4" CornerRadius="4">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="running">
                                                        <Setter Property="Background" Value="#0C1A2E"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="error">
                                                        <Setter Property="Background" Value="#1A0A10"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Label}" FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{Binding TextColor}"
                                                           FontWeight="{Binding Weight}"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding Tipo}" FontFamily="Consolas"
                                                               FontSize="8" Foreground="{Binding TipoColor}"
                                                               Margin="0,1,0,0"/>
                                                    <TextBlock Text="{Binding EstStr}"
                                                               Visibility="{Binding EstVisible}"
                                                               FontFamily="Consolas" FontSize="8"
                                                               Foreground="#283C5A" Margin="5,1,0,0"/>
                                                </StackPanel>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding TimeStr}"
                                                       FontFamily="Consolas" FontSize="9"
                                                       Foreground="{Binding TimeColor}"
                                                       VerticalAlignment="Center" Margin="6,0,0,0"/>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>

        <!-- Divider bottom -->
        <Border Grid.Row="4" Background="#1E2A45"/>

        <!-- ══ FOOTER ══ -->
        <Grid Grid.Row="5" Margin="52,0">
            <TextBlock Text="NovaSCM 1.8.2" FontFamily="Consolas" FontSize="9"
                       Foreground="#1E2A45" VerticalAlignment="Center"/>
            <TextBlock Text="▲  Non spegnere il PC durante la configurazione"
                       FontFamily="Consolas" FontSize="9.5" Foreground="#6B500A"
                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock x:Name="TxtOsdElapsed" Text=""
                       FontFamily="Consolas" FontSize="9" Foreground="#1E2A45"
                       HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <!-- ══ OVERLAY COMPLETATO ══ -->
        <Grid x:Name="OvDone" Grid.RowSpan="6" Panel.ZIndex="10"
              Visibility="Collapsed">
            <Grid.Background>
                <SolidColorBrush Color="#05080f" Opacity="0.96"/>
            </Grid.Background>
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="860">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="280"/>
                        <ColumnDefinition Width="40"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Sinistra: check + titolo + chips + countdown -->
                    <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                        <Border Width="90" Height="90" CornerRadius="45" HorizontalAlignment="Center"
                                BorderThickness="2" BorderBrush="#00D97E" Margin="0,0,0,14">
                            <Border.Background>
                                <SolidColorBrush Color="#00D97E" Opacity="0.08"/>
                            </Border.Background>
                            <TextBlock Text="✓" FontSize="38" Foreground="#00D97E"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="Configurazione" FontSize="26" FontWeight="Light"
                                   Foreground="#E8F0FF" HorizontalAlignment="Center"/>
                        <TextBlock Text="completata" FontSize="26" FontWeight="Light"
                                   Foreground="#E8F0FF" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock x:Name="TxtOvHost" Text="—"
                                   FontFamily="Consolas" FontSize="12" Foreground="#00D97E"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <Border Padding="10,5" CornerRadius="4" HorizontalAlignment="Center"
                                BorderThickness="1" BorderBrush="#1E2A45" Margin="0,0,0,14">
                            <Border.Background>
                                <SolidColorBrush Color="#FFFFFF" Opacity="0.02"/>
                            </Border.Background>
                            <TextBlock x:Name="TxtOvDetail" Text="—"
                                       FontFamily="Consolas" FontSize="10" Foreground="#829696"
                                       HorizontalAlignment="Center"/>
                        </Border>
                        <WrapPanel x:Name="OvHwChips" HorizontalAlignment="Center" Margin="0,0,0,18"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <TextBlock Text="Riavvio tra " FontFamily="Consolas" FontSize="10"
                                       Foreground="#829696" VerticalAlignment="Center"/>
                            <TextBlock x:Name="TxtRebootN" Text="30"
                                       FontFamily="Consolas" FontSize="14" FontWeight="Medium"
                                       Foreground="#F5A623" VerticalAlignment="Center"/>
                            <TextBlock Text="s" FontFamily="Consolas" FontSize="10"
                                       Foreground="#829696" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Destra: screenshot box -->
                    <Border Grid.Column="2" CornerRadius="8" BorderThickness="1" BorderBrush="#1E2A45">
                        <Border.Background>
                            <SolidColorBrush Color="#0A0F1E" Opacity="0.8"/>
                        </Border.Background>
                        <StackPanel>
                            <Border BorderThickness="0,0,0,1" BorderBrush="#1E2A45" Padding="12,7">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="📷" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                    <TextBlock Text="Screenshot finale — "
                                               FontFamily="Consolas" FontSize="8"
