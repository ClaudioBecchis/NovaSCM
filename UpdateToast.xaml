<!-- NovaSCM v1.6.0 -->
<Window x:Class="PolarisManager.UpdateToast"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False" Topmost="True"
        SizeToContent="WidthAndHeight"
        WindowStartupLocation="Manual">

    <Border Background="#1a1200" BorderBrush="#f59e0b" BorderThickness="1"
            CornerRadius="8" Padding="16,12">
        <Border.Effect>
            <DropShadowEffect BlurRadius="16" ShadowDepth="4" Opacity="0.5" Color="#000000"/>
        </Border.Effect>
        <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="🔄 " FontSize="18" VerticalAlignment="Center"/>
                <TextBlock Text="Aggiornamento disponibile" FontSize="14" FontWeight="Bold"
                           Foreground="#fbbf24" VerticalAlignment="Center"/>
            </StackPanel>
            <TextBlock x:Name="TxtVersion" Text="NovaSCM v1.6.0"
                       Foreground="#e2e8f0" FontSize="13" Margin="0,0,0,4"/>
            <TextBlock x:Name="TxtNotes" Text="" Foreground="#94a3b8"
                       FontSize="12" Margin="0,0,0,12" TextWrapping="Wrap" MaxWidth="280"/>
            <StackPanel Orientation="Horizontal">
                <Button x:Name="BtnInstall" Content="⬇️  Installa ora"
                        Background="#0c2d1a" BorderBrush="#16a34a" Foreground="#4ade80"
                        Padding="12,6" FontSize="12" FontWeight="SemiBold" Cursor="Hand"
                        Margin="0,0,8,0" Click="BtnInstall_Click"/>
                <Button Content="✕" Background="Transparent" BorderBrush="#334155"
                        Foreground="#475569" Padding="8,6" FontSize="12" Cursor="Hand"
                        Click="BtnClose_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
